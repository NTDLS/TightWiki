		<PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="10.0.5" />
		<PackageReference Include="NTDLS.Helpers" Version="1.3.19" />
		<PackageReference Include="NTDLS.SqliteDapperWrapper" Version="1.4.0" />
