@page
@using TightWiki.Library
@using TightWiki.Models
@inject IViewLocalizer Localizer
@model AccountsModel
@{
    ViewData["Title"] = Localizer["Accounts"];
}

<div>
    <h3>@Localizer["Accounts"]</h3>

    <p>@Localizer["Global configuration for user accounts."]</p>

    <div class="d-flex justify-content-between align-items-center mb-3" id="toolbar">
        <div>
            @*Left-aligned "toolbar" controls*@
            <a class="btn btn-success btn-sm me-2" href="@GlobalConfiguration.BasePath/Admin/AddAccount">
                @Localizer["Add new account"]
            </a>
        </div>

        <div>
            @*Right-aligned "toolbar" controls*@
        </div>
    </div>

    @using (Html.BeginForm())
    {
        <div class="d-flex justify-content-end mb-4">
            <div class="flex-grow-1 me-2">
                @Html.TextBoxFor(x => x.SearchString, new { @class = "form-control" })
            </div>
            <button type="submit" value="Search" class="btn btn-primary">@Localizer["Search"]</button>
        </div>

        <div class="d-flex small text-muted mb-0 d-none">
            <strong>
                @Localizer["Either there are no accounts configured or your search criteria returned no results."]
            </strong>
        </div>

        <div id="accountTable" class="mt-3"></div>
    }
</div>

<script>
    window.onload = function () {
        document.getElementById("SearchString").focus();
    }

    const accountTable = new Tabulator("#accountTable", {
        layout: "fitColumns",
        ajaxURL: "/Admin/AccountsPaged",
        ajaxConfig: "GET",
        pagination: "remote",
        paginationSize: @GlobalConfiguration.PaginationSize,
        paginationDataSent: {
            page: "page",
            size: "size",
            sorters: "sort",
        },
        ajaxParams: function () {
            return {
                page: accountTable.getPage(),
                size: accountTable.getPageSize(),
                searchString: document.getElementById("SearchString").value
            };
        },
        ajaxResponse: function (url, params, response) {
            return response.data;
        },
        columns: [
            {
                title: "@Localizer["Account"]",
                field: "accountName",
                formatter: function(cell) {
                    const navigation = cell.getRow().getData().navigation;
                    return `<a href="@GlobalConfiguration.BasePath/Admin/Account/${navigation}">${cell.getValue()}</a>`;
                }
            },
            { title: "@Localizer["First Name"]", field: "firstName" },
            { title: "@Localizer["Last Name"]", field: "lastName" },
            { title: "@Localizer["Country"]", field: "country" },
            { title: "@Localizer["TimeZone"]", field: "timeZone" },
            {
                title: "@Localizer["EmailAddress"]",
                field: "emailAddress",
                formatter: function(cell) {
                    const confirmed = cell.getRow().getData().emailConfirmed;
                    const check = confirmed ? " ✓" : "";
                    return cell.getValue() + check;
                }
            },
            { title: "@Localizer["CreatedDate"]", field: "createdDate" }
        ]
    });
</script>
