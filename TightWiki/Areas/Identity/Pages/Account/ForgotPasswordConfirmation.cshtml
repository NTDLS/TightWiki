@page

@using TightWiki.Resources

@model ForgotPasswordConfirmation
@{
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<h3>
    @SharedLocalizer.Static["Forgot password confirmation"]
</h3>

<p>
    @SharedLocalizer.Static["Please check your email to reset your password."]
</p>
