@page
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki
@using TightWiki.Models
@using System.Text.Encodings.Web
@using TightWiki.Library
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model RegisterModel
@{
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Create a new account"]</h3>
        <div class="text-muted">
            @Localizer["Create your account and configure your basic profile details."]
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 @( (Model.ExternalLogins?.Count ?? 0) > 0 ? "col-lg-8" : "col-lg-10 col-xl-8")">
        <div class="card shadow-sm">
            <div class="card-header">
                <span class="fw-semibold">
                    <i class="bi bi-person-plus me-2"></i>@Localizer["Register"]
                </span>
            </div>

            <div class="card-body">
                <form id="registerForm" asp-route-returnUrl="@(Model.ReturnUrl ?? "")" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="Input_Email" class="form-label fw-semibold">
                                @Localizer["Email Address"]
                            </label>
                            @Html.TextBoxFor(m => m.Input.Email, new
                            {
                                @class = "form-control",
                                autocomplete = "email",
                                placeholder = "name@example.com",
                                id = "Input_Email"
                            })
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.Email)
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="Input_Password" class="form-label fw-semibold">
                                @Localizer["Password"]
                            </label>
                            @Html.PasswordFor(m => m.Input.Password, new
                            {
                                @class = "form-control",
                                autocomplete = "new-password",
                                placeholder= Localizer["Required"].Value,
                                id = "Input_Password"
                            })
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.Password)
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="Input_ConfirmPassword" class="form-label fw-semibold">
                                @Localizer["Confirm Password"]
                            </label>
                            @Html.PasswordFor(m => m.Input.ConfirmPassword, new
                            {
                                @class = "form-control",
                                autocomplete = "new-password",
                                placeholder= Localizer["Required"].Value,
                                id = "Input_ConfirmPassword"
                            })
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.ConfirmPassword)
                            </div>
                        </div>

                        <div class="col-12">
                            <label for="Input_AccountName" class="form-label fw-semibold">
                                @Localizer["Display Name"]
                            </label>
                            @Html.TextBoxFor(m => m.Input.AccountName, new
                            {
                                @class = "form-control",
                                placeholder= Localizer["Required"].Value,
                                id = "Input_AccountName"
                            })
                            <div class="form-text">
                                @Localizer["This display name will be visible publicly."]
                            </div>
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.AccountName)
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="Input_FirstName" class="form-label fw-semibold">
                                @Localizer["First Name"]
                            </label>
                            @Html.TextBoxFor(m => m.Input.FirstName, new
                            {
                                @class = "form-control",
                                placeholder= Localizer["Optional"].Value,
                                id = "Input_FirstName"
                            })
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.FirstName)
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="Input_LastName" class="form-label fw-semibold">
                                @Localizer["Last Name"]
                            </label>
                            @Html.TextBoxFor(m => m.Input.LastName, new
                            {
                                @class = "form-control",
                                placeholder= Localizer["Optional"].Value,
                                id = "Input_LastName"
                            })
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.LastName)
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="Input_Country" class="form-label fw-semibold">
                                @Localizer["Country"]
                            </label>
                            <select name="Input.Country" id="Input_Country" class="form-select">
                                <option value="">@Localizer["Select a country"]</option>
                                @foreach (var item in Model.Input.Countries)
                                {
                                    <option value="@item.Value" selected="@(Model.Input.Country == item.Value ? "selected" : null)">
                                        @item.Text
                                    </option>
                                }
                            </select>
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.Country)
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="Input_Language" class="form-label fw-semibold">
                                @Localizer["Language"]
                            </label>
                            <select name="Input.Language" id="Input_Language" class="form-select">
                                <option value="">@Localizer["Select a language"]</option>
                                @foreach (var item in Model.Input.Languages)
                                {
                                    <option value="@item.Value" selected="@(Model.Input.Language == item.Value ? "selected" : null)">
                                        @item.Text
                                    </option>
                                }
                            </select>
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.Language)
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="Input_TimeZone" class="form-label fw-semibold">
                                @Localizer["Time Zone"]
                            </label>
                            <select name="Input.TimeZone" id="Input_TimeZone" class="form-select">
                                <option value="">@Localizer["Select a time-zone"]</option>
                                @foreach (var item in Model.Input.TimeZones)
                                {
                                    <option value="@item.Value" selected="@(Model.Input.TimeZone == item.Value ? "selected" : null)">
                                        @item.Text
                                    </option>
                                }
                            </select>
                            <div class="text-danger small">
                                @Html.ValidationMessageFor(m => m.Input.TimeZone)
                            </div>
                        </div>

                        <div class="col-12">
                            <button id="login-submit" type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-person-plus me-1"></i>@Localizer["Signup"]
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <span class="fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["Use another service to register"]
                    </span>
                </div>

                <div class="card-body">
                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@UrlEncoder.Default.Encode(Model.ReturnUrl ?? "")"
                          method="post">
                        <div class="d-flex flex-column gap-3">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                if (provider.Name == "Google")
                                {
                                    <button type="submit"
                                            class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your Google account">
                                        <img src="@WikiConfiguration.BasePath/images/external/google-signin.svg"
                                             alt="Google"
                                             class="me-2"
                                             style="max-height: 50px;" />
                                    </button>
                                }
                                else if (provider.Name == "Microsoft")
                                {
                                    <button type="submit"
                                            class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your Microsoft account">
                                        <img src="@WikiConfiguration.BasePath/images/external/microsoft-signin.svg"
                                             alt="Microsoft"
                                             class="me-2"
                                             style="max-height: 50px;" />
                                    </button>
                                }
                                else
                                {
                                    <button type="submit"
                                            class="btn btn-outline-primary w-100"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account">
                                        @provider.DisplayName
                                    </button>
                                }
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}