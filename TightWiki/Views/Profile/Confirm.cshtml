@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Profile
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model ConfirmViewModel
@{
    Layout = "_Layout";
}
<div class="card shadow-lg">
    <div class="card-header">
        <h3>@Localizer["Account Email Verification"]</h3>
    </div>
    <div class="card-body">
        <p>
            @Localizer["Already a member?"] <a href="@WikiConfiguration.BasePath/Account/Login">@Localizer["Login"]</a>.<br />
            @Localizer["Forgot your password?"] @Html.ActionLink(Localizer["Reset it"].Value, "Forgot", "Account").<br />
        </p>
    </div>
</div>
