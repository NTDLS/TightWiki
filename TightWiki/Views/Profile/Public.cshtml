@using TightWiki
@using TightWiki.Models
@using TightWiki.Library
@inject ISharedLocalizationText Localizer
@inject TightWikiConfiguration WikiConfiguration

@model TightWiki.Models.ViewModels.Profile.PublicViewModel
@{
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Profile"]
        </h3>
        <div class="text-muted">
            @Localizer["Public profile information."]
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Navigation))
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-4">
                <div class="col-12 col-md-4 col-lg-3 text-center">
                    <img src="@WikiConfiguration.BasePath/Profile/@Model.Navigation/Avatar?max=150"
                         alt="@Model.AccountName"
                         class="img-thumbnail"
                         style="max-width: 150px; max-height: 150px;" />
                </div>

                <div class="col-12 col-md-8 col-lg-9">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <tbody>
                                <tr>
                                    <th scope="row" style="width: 180px;">@Localizer["Name"]</th>
                                    <td>@Html.DisplayFor(m => m.AccountName)</td>
                                </tr>
                                <tr>
                                    <th scope="row">@Localizer["Country"]</th>
                                    <td>@Html.DisplayFor(m => m.Country)</td>
                                </tr>
                                <tr>
                                    <th scope="row">@Localizer["Language"]</th>
                                    <td>@Html.DisplayFor(m => m.Language)</td>
                                </tr>
                                <tr>
                                    <th scope="row">@Localizer["Time Zone"]</th>
                                    <td>@Html.DisplayFor(m => m.TimeZone)</td>
                                </tr>
                                <tr>
                                    <th scope="row">@Localizer["Biography"]</th>
                                    <td>
                                        <div class="text-break">
                                            @Html.Raw(Model.Biography)
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountName)</div>
                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.Country)</div>
                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.Language)</div>
                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.TimeZone)</div>
                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.Biography)</div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.RecentlyModified.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-header">
            <span class="fw-semibold">
                <i class="bi bi-clock-history me-2"></i>@Localizer["Recently Modified"]
            </span>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">@Localizer["Page"]</th>
                        <th scope="col" class="text-nowrap">@Localizer["Modified"]</th>
                        <th scope="col">@Localizer["Analysis"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model.RecentlyModified)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@h.Navigation">
                                    @Html.DisplayTextFor(x => h.Name)
                                </a>
                            </td>
                            <td class="text-nowrap text-muted">
                                @Html.DisplayTextFor(x => h.ModifiedDate)
                            </td>
                            <td>
                                @Html.DisplayTextFor(x => h.ChangeAnalysis)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}