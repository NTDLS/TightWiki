@using TightWiki.Library
@using TightWiki.Models

@using TightWiki.Resources

@model TightWiki.Models.ViewModels.Profile.AccountProfileViewModel
@{
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@SharedLocalizer.Static["Profile"]</h3>
        <div class="text-muted">@SharedLocalizer.Static["This is your profile, do with it what you may."]</div>
    </div>
</div>

@using (Html.BeginForm(null, null, null, FormMethod.Post, true, new { action = $"{GlobalConfiguration.BasePath}{Context.Request.Path}", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-person-circle me-2"></i>@SharedLocalizer.Static["Profile Settings"]
            </span>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-floppy me-1"></i>@SharedLocalizer.Static["Save"]
                </button>

                @ConfirmActionHelper.GenerateDangerButton(
                    GlobalConfiguration.BasePath,
                    SharedLocalizer.Static["Deleting '{0}' will permanently remove the account. All pages created or modified by this user will be attributed to a stand-in account and you will not be able to revert this action. Continue?"].Format(Model.AccountProfile.AccountName),
                    SharedLocalizer.Static["Delete Account"].Value,
                    $"/Profile/Delete",
                    $"{GlobalConfiguration.BasePath}/Profile/Deleted",
                    Context.Request.Path.Value)
            </div>
        </div>

        <div class="card-body">
            @Html.HiddenFor(m => m.AccountProfile.UserId)
            @Html.HiddenFor(m => m.AccountProfile.Navigation)

            <div class="row g-4">
                <div class="col-12 col-lg-4">
                    <div class="card h-100 border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-image me-2"></i>@SharedLocalizer.Static["Avatar"]
                        </div>
                        <div class="card-body text-center">
                            <div id="avatar-preview-container">
                                @if (!string.IsNullOrWhiteSpace(Model.AccountProfile.Navigation))
                                {
                                    <img id="avatar-preview"
                                         src="@GlobalConfiguration.BasePath/Profile/@Model.AccountProfile.Navigation/Avatar?max=150"
                                         alt="Image Preview"
                                         class="img-thumbnail"
                                         style="max-width: 200px; max-height: 200px;" />
                                }
                                else
                                {
                                    <div class="text-muted small">
                                        @SharedLocalizer.Static["No avatar uploaded."]
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer text-center">
                            <label for="avatar" class="btn btn-outline-primary mb-0">
                                <i class="bi bi-upload me-1"></i>@SharedLocalizer.Static["Change Avatar"]
                            </label>
                            <input type="file" id="avatar" name="Avatar" accept="image/*" class="d-none" />
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-8">
                    <div class="card h-100 border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-person-lines-fill me-2"></i>@SharedLocalizer.Static["Profile Details"]
                        </div>

                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">@SharedLocalizer.Static["Email Address"]</label>
                                    <div class="form-control-plaintext border rounded px-3 py-2 bg-light">
                                        @Html.DisplayFor(m => m.AccountProfile.EmailAddress)
                                    </div>
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.EmailAddress)
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label for="AccountProfile_AccountName" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Display Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.AccountName, new { @class = "form-control" })
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.AccountName)
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <label for="AccountProfile_FirstName" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["First Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.FirstName, new { @class = "form-control" })
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.FirstName)
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <label for="AccountProfile_LastName" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Last Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.LastName, new { @class = "form-control" })
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.LastName)
                                    </div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="AccountProfile_Theme" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Theme"]
                                    </label>
                                    <select name="AccountProfile.Theme" id="AccountProfile_Theme" class="form-select">
                                        <option value="">@SharedLocalizer.Static["System Default"]</option>
                                        @foreach (var item in Model.Themes)
                                        {
                                            <option value="@item.Name" selected="@(Model.AccountProfile.Theme == item.Name ? "selected" : null)">
                                                @item.Name
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.Theme)
                                    </div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="AccountProfile_Country" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Country"]
                                    </label>
                                    <select name="AccountProfile.Country" id="AccountProfile_Country" class="form-select">
                                        <option value="">@SharedLocalizer.Static["Select a country"]</option>
                                        @foreach (var item in Model.Countries)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.Country == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.Country)
                                    </div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="AccountProfile_Language" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Language"]
                                    </label>
                                    <select name="AccountProfile.Language" id="AccountProfile_Language" class="form-select">
                                        <option value="">@SharedLocalizer.Static["Select a language"]</option>
                                        @foreach (var item in Model.Languages)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.Language == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.Language)
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label for="AccountProfile_TimeZone" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Time Zone"]
                                    </label>
                                    <select name="AccountProfile.TimeZone" id="AccountProfile_TimeZone" class="form-select">
                                        <option value="">@SharedLocalizer.Static["Select a time-zone"]</option>
                                        @foreach (var item in Model.TimeZones)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.TimeZone == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.TimeZone)
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label for="Biography" class="form-label fw-semibold">
                                        @SharedLocalizer.Static["Biography"]
                                    </label>
                                    @Html.TextAreaFor(m => m.AccountProfile.Biography, new
                                    {
                                        @class = "form-control",
                                        style = "min-height: 220px",
                                        Name = "Biography"
                                    })
                                    <div class="text-danger small">
                                        @Html.ValidationMessageFor(m => m.AccountProfile.Biography)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let fileInput = document.getElementById("avatar");

        if (fileInput) {
            fileInput.addEventListener("change", function (event) {
                let file = event.target.files[0];
                if (file) {
                    let reader = new FileReader();

                    reader.onload = function (e) {
                        let preview = document.getElementById("avatar-preview");
                        let previewContainer = document.getElementById("avatar-preview-container");

                        if (preview) {
                            preview.src = e.target.result;
                        } else if (previewContainer) {
                            previewContainer.innerHTML =
                                `<img id="avatar-preview"
                                      src="${e.target.result}"
                                      alt="Image Preview"
                                      class="img-thumbnail"
                                      style="max-width: 200px; max-height: 200px;" />`;
                        }
                    };

                    reader.readAsDataURL(file);
                }
            });
        }
    });
</script>