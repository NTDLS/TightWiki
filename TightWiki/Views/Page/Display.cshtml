@using TightWiki.Library
@using TightWiki.Models
@using static TightWiki.Library.Constants
@inject ISharedLocalizationText Localizer

@model TightWiki.Models.ViewModels.Page.PageDisplayViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<!-- Syntax Highlighter:Begin -->
<script src="@Url.Content("~/syntax/highlight.min.js")"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
    hljs.highlightAll();
    });
</script>
<!-- Syntax Highlighter:End -->
@if (Model.Revision < Model.MostCurrentRevision)
{
    <div class="card shadow-sm border-info mb-4">
        <div class="card-header bg-info-subtle border-info">
            <div class="fw-semibold text-dark">
                <i class="bi bi-clock-history me-2"></i>@Localizer["Viewing a historical version"]
            </div>
        </div>
        <div class="card-body">
            <div class="mb-3">
                @Localizer.Format("You are viewing revision {0} of \"{1}\" modified by {2} on {3}.",
                    Model.Revision,
                    Model.Name,
                    Model.ModifiedByUserName,
                    Model.ModifiedDate)
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary btn-sm"
                       href="@GlobalConfiguration.BasePath/@Model.Navigation">
                    <i class="bi bi-arrow-clockwise me-1"></i>@Localizer["View latest revision"]
                </a>

                @if (await sessionState.HoldsPermission(WikiPermission.Moderate))
                {
                    <a class="btn btn-warning btn-sm"
                           href="@GlobalConfiguration.BasePath/@Model.Navigation/revert/@Model.Revision">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>@Localizer["Revert to revision"] @Model.Revision
                    </a>
                }
            </div>
        </div>
    </div>
}

<div class="wiki-page-body">
    @Html.Raw(Model.Body)
</div>

@if (TightWiki.Models.GlobalConfiguration.ShowLastModifiedOnPageFooter
    && string.IsNullOrWhiteSpace(Model.ModifiedByUserName) == false
    && Model.HideFooterLastModified != true)
{
    <div class="mt-4 text-muted small">
        @if (TightWiki.Models.GlobalConfiguration.EnablePublicProfiles)
        {
            <cite title="Modified By">
                @Localizer["Last modified by"]
                <a class="text-decoration-none"
                       href="@GlobalConfiguration.BasePath/Profile/@Model.ModifiedByUserName/Public">
                    @Model.ModifiedByUserName
                </a>
                <span class="mx-1">•</span>@Model.ModifiedDate
            </cite>
        }
        else
        {
            <cite title="Modified By">
                @Localizer["Last modified by"] @Model.ModifiedByUserName
                <span class="mx-1">•</span>@Model.ModifiedDate
            </cite>
        }
    </div>
}

@if (Model.HideFooterComments == false
    && TightWiki.Models.GlobalConfiguration.EnablePageComments
    && TightWiki.Models.GlobalConfiguration.ShowCommentsOnPageFooter)
{
    <hr class="mt-5 mb-4" />

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h2 class="h4 mb-1">@Localizer["Comments"]</h2>
        </div>
    </div>

    @if (sessionState.IsAuthenticated == true)
    {
        <form method="post" action="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Comments">
            <div class="row g-2 align-items-center mb-3">
                <div class="col-12 col-md">
                    <input type="text"
                           name="Comment"
                           id="Comment"
                           class="form-control"
                           placeholder="@Localizer["Type comment..."]" />
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" value="Post" class="btn btn-primary w-100">
                        <i class="bi bi-send me-1"></i>@Localizer["Post"]
                    </button>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <a class="text-decoration-none"
                       href="@GlobalConfiguration.BasePath/Identity/Account/Login?returnUrl=@Context.Request.Path.Value">
                    @Localizer["Login to leave a comment"]
                </a>
            </div>
        </div>
    }

    @if (Model.Comments != null && Model.Comments.Count > 0)
    {
        <div class="d-flex flex-column gap-3 mb-3">
            @foreach (var h in Model.Comments)
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="mb-3">
                            @Html.Raw(h.Body)
                        </div>

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex align-items-center flex-wrap gap-2 small text-muted">
                                <img src="@GlobalConfiguration.BasePath/Profile/@h.UserNavigation/Avatar?Exact=24"
                                     class="rounded-circle"
                                     alt="Avatar"
                                     width="24"
                                     height="24" />

                                <a href="@GlobalConfiguration.BasePath/Profile/@h.UserNavigation/Public"
                                       class="text-decoration-none">
                                    @Html.DisplayTextFor(x => h.UserName)
                                </a>

                                <span>•</span>

                                <span>@Html.DisplayTextFor(x => h.CreatedDate)</span>
                            </div>

                            @if (await sessionState.HoldsPermission(WikiPermission.Moderate) || h.UserId == sessionState.Profile?.UserId)
                            {
                                <a href="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Comments?Delete=@h.Id"
                                       class="small text-danger text-decoration-none"
                                       onclick="return confirm('@Localizer["Are you sure you want to delete this comment?"]')">
                                    @Localizer["Delete"]
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-2">
        <a class="text-decoration-none"
               href="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Comments">
            @Localizer["View all comments"]
        </a>
    </div>
}