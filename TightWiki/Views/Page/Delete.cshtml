@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Page
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PageDeleteViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

@if (string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="card shadow-sm border-danger mb-3">
        <div class="card-header bg-danger-subtle border-danger">
            <div class="fw-semibold text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @Localizer.Format("Delete page '{0}'?", Model.PageName)
            </div>
        </div>

        <div class="card-body">
            <div class="mb-3">
                @Localizer.Format("Deleting '{0}' will move the page, with all {1} revisions and {2} file attachments to the deletion queue.",
                    Model.PageName,
                    Model.PageRevision,
                    Model.CountOfAttachments)
            </div>

            <div class="mb-3 text-danger">
                @Localizer["This action can only be undone by a moderator or administrator."]
            </div>

            <div class="mb-4 fw-semibold">
                @Localizer["Are you sure you want to continue with this deletion?"]
            </div>

            @using (Html.BeginForm(FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit"
                            class="btn btn-danger"
                            name="IsActionConfirmed"
                            value="true">
                        <i class="bi bi-trash me-1"></i>@Localizer["Yes"]
                    </button>

                    <button type="submit"
                            class="btn btn-success"
                            name="IsActionConfirmed"
                            value="false">
                        <i class="bi bi-x-circle me-1"></i>@Localizer["No"]
                    </button>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning-subtle border-warning">
            <div class="fw-semibold text-dark">
                <i class="bi bi-exclamation-circle me-2"></i>@Localizer["Unable to delete page"]
            </div>
        </div>
        <div class="card-body text-muted">
            @Model.ErrorMessage
        </div>
    </div>
}