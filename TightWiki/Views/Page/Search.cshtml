@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Page
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PageSearchViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Page Search"]
        </h3>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Get))
{
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <span class="fw-semibold">
                <i class="bi bi-search me-2"></i>@Localizer["Search"]
            </span>
        </div>

        <div class="card-body">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md">
                    @Html.TextBoxFor(x => x.SearchString, new
                    {
                        @class = "form-control",
                        placeholder= Localizer["Search pages..."].Value
                    })
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" value="Find" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>@Localizer["Search"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Pages.Count > 0)
    {
        <div class="card shadow-sm">
            <div class="card-body pb-0">
                @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
            </div>

            <div class="table-responsive mt-0">
                <table class="table table-striped table-hover align-middle mb-0">
                    <tbody>
                        @foreach (var p in Model.Pages)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.Namespace))
                                    {
                                        <span class="text-muted">@p.Namespace :: </span>
                                    }

                                    <a class="text-decoration-none fw-semibold"
                                           href="@WikiConfiguration.BasePath/@p.Navigation">
                                        @p.Title
                                    </a>

                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <span class="text-muted"> : </span>
                                        <span>@p.Description</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-body pt-3">
                @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.SearchString))
    {
        <div class="card shadow-sm">
            <div class="card-body text-muted">
                <i class="bi bi-search me-2"></i>
                @Localizer["Your search criteria resulted in no pages, simplify your search text."]
            </div>
        </div>
    }
}

<script>
    window.onload = function () {
        document.getElementById("SearchString")?.focus();
    }
</script>