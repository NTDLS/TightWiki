@using DiffPlex.DiffBuilder.Model
@using Microsoft.AspNetCore.Html
@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Page
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PageCompareViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

@if (sessionState.UserTheme.EditorTheme == "dark")
{
    <link rel="stylesheet" href="@WikiConfiguration.BasePath/css/diffPlexDark.css" />
}
else
{
    <link rel="stylesheet" href="@WikiConfiguration.BasePath/css/diffPlexLight.css" />
}

@functions {
    string RowClass(DiffPlex.DiffBuilder.Model.ChangeType t) => t switch
    {
        ChangeType.Inserted => "inserted",
        ChangeType.Deleted => "deleted",
        ChangeType.Modified => "modified",
        ChangeType.Imaginary => "imaginary",
        _ => "unchanged"
    };

    IHtmlContent RenderPieces(IReadOnlyList<DiffPiece> pieces)
    {
        if (pieces is null || pieces.Count == 0) return Html.Raw("");
        var sb = new System.Text.StringBuilder();
        foreach (var p in pieces)
        {
            var txt = (p.Text ?? "").Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
            var cls = p.Type switch { ChangeType.Inserted => "w-ins", ChangeType.Deleted => "w-del", _ => null };
            if (cls is null) sb.Append(txt); else sb.Append($"<span class=\"{cls}\">{txt}</span>");
        }
        return Html.Raw(sb.ToString());
    }

    IHtmlContent RenderLine(DiffPiece? line)
    {
        if (line is null) return Html.Raw("");
        if (line.SubPieces?.Count > 0) return RenderPieces(line.SubPieces);
        var txt = (line.Text ?? "").Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
        return Html.Raw(txt);
    }
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Page Revisions"]
        </h3>
        <div class="text-muted">
            @Localizer["Review the differences between revisions of this page."]
        </div>
        <div class="mt-1">
            <span class="text-muted">@Localizer["Page"]:</span>
            <a class="text-decoration-none fw-semibold"
                   href="@WikiConfiguration.BasePath/@sessionState.PageNavigation">
                @sessionState.Page.Name
            </a>
        </div>
    </div>
</div>

@if (Model.ThisRevision == null || Model.DiffModel == null)
{
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning-subtle border-warning">
            <div class="fw-semibold text-dark">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localizer["Revision not found"]
            </div>
        </div>
        <div class="card-body">
            @Localizer["The requested page or revision does not exist."]
        </div>
    </div>
}
else
{
    string disablePrev = (Model.PreviousRevision ?? 0) == 0 ? "disabled" : "";
    string disableNext = Model.MostCurrentRevision == Model.ThisRevision ? "disabled" : "";

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-arrow-left-right me-2"></i>@Localizer["Revision Comparison"]
            </span>

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary btn-sm"
                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/Revisions">
                    <i class="bi bi-clock-history me-1"></i>@Localizer["View all revisions"]
                </a>

                <a class="btn btn-outline-success btn-sm @disablePrev"
                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/Compare/@(Model.PreviousRevision ?? 0)"
                   aria-disabled="@(disablePrev == "disabled" ? "true" : "false")">
                    <i class="bi bi-arrow-left me-1"></i>@Localizer["Previous"]
                </a>

                <a class="btn btn-outline-success btn-sm @disableNext"
                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/Compare@("/")@((Model.ThisRevision ?? 0) + 1)"
                   aria-disabled="@(disableNext == "disabled" ? "true" : "false")">
                    @Localizer["Next"]<i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="text-muted">
                @Localizer["Revision"]:
                <a class="text-decoration-none fw-semibold"
                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/@Model.ThisRevision">
                    @(Model.ThisRevision ?? 0)
                </a>
                <span class="mx-1">•</span>
                @Localizer["Modified by"]:
                <a class="text-decoration-none"
                       href="@WikiConfiguration.BasePath/Profile/@Model.ModifiedByUserName/Public">
                    @Model.ModifiedByUserName
                </a>
                <span class="mx-1">•</span>
                @Localizer["Modified date"]: @Model.ModifiedDate
            </div>
        </div>
    </div>

    @if (WikiConfiguration.ShowChangeSummaryWhenEditing && !string.IsNullOrEmpty(Model.ChangeSummary))
    {
        <div class="alert alert-secondary py-2 mb-3">
            <strong>@Localizer["Summary"]:</strong> @Model.ChangeSummary
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header">
            <span class="fw-semibold">
                <i class="bi bi-file-diff me-2"></i>@Localizer["Differences"]
            </span>
        </div>
        <div class="card-body p-0">
            <div class="diff-wrap">
                <table class="diff-table">
                    <thead class="diff-head">
                        <tr>
                            <th class="ln">Old</th>
                            <th class="gutter"></th>
                            <th class="code">Text</th>
                            <th class="ln">New</th>
                            <th class="gutter"></th>
                            <th class="code">Text</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var oldLines = Model.DiffModel.OldText.Lines;
                            var newLines = Model.DiffModel.NewText.Lines;

                            var count = Math.Max(oldLines.Count, newLines.Count);
                            for (int i = 0; i < count; i++)
                            {
                                var o = i < oldLines.Count ? oldLines[i] : null;
                                var n = i < newLines.Count ? newLines[i] : null;

                                var lcO = RowClass(o?.Type ?? ChangeType.Imaginary);
                                var lcN = RowClass(n?.Type ?? ChangeType.Imaginary);

                                <tr>
                                    <td class="ln">@o?.Position</td>
                                    <td class="gutter"><div class="bar"></div></td>
                                    <td class="@lcO">@RenderLine(o)</td>
                                    <td class="ln">@n?.Position</td>
                                    <td class="gutter"><div class="bar"></div></td>
                                    <td class="@lcN">@RenderLine(n)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}