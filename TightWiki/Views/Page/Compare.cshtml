@using Microsoft.AspNetCore.Html
@using DiffPlex.DiffBuilder.Model
@using TightWiki.Models
@inject IViewLocalizer Localizer
@model TightWiki.Models.ViewModels.Page.PageCompareViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

@if (@sessionState.UserTheme.EditorTheme == "dark")
{
    <link rel="stylesheet" href="@GlobalConfiguration.BasePath/css/diffPlexDark.css" />
}
else
{
    <link rel="stylesheet" href="@GlobalConfiguration.BasePath/css/diffPlexLight.css" />
}

<style>
    tr.chunk-toolbar td.chunk-toolbar-cell {
        padding: 0px;
        white-space: normal !important;
    }

    .chunk-toolbar-inner {
        white-space: normal !important;
        width: 100% !important;
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    tr.diff-row.chunk-old-picked td.new-cell {
        opacity: .35;
    }

    tr.diff-row.chunk-new-picked td.old-cell {
        opacity: .35;
    }
</style>

@functions {
    record DiffChunk(int Index, int Start, int End);

    string RowClass(DiffPlex.DiffBuilder.Model.ChangeType t) => t switch
    {
        ChangeType.Inserted => "inserted",
        ChangeType.Deleted => "deleted",
        ChangeType.Modified => "modified",
        ChangeType.Imaginary => "imaginary",
        _ => "unchanged"
    };

    static bool IsChanged(DiffPiece? o, DiffPiece? n)
    {
        var ot = o?.Type ?? ChangeType.Imaginary;
        var nt = n?.Type ?? ChangeType.Imaginary;

        // Treat Imaginary as "no line". We only consider it changed if the other side isn't unchanged.
        bool oChanged = ot != ChangeType.Unchanged && ot != ChangeType.Imaginary;
        bool nChanged = nt != ChangeType.Unchanged && nt != ChangeType.Imaginary;

        // If either side is inserted/deleted/modified, it's changed.
        // Also if one side is imaginary and the other is inserted/deleted/modified, it's changed.
        return (ot != ChangeType.Unchanged) || (nt != ChangeType.Unchanged);
    }

    static List<DiffChunk> BuildChunks(IReadOnlyList<DiffPiece> oldLines, IReadOnlyList<DiffPiece> newLines)
    {
        var max = Math.Max(oldLines.Count, newLines.Count);
        var chunks = new List<DiffChunk>();
        int i = 0;
        int chunkIndex = 0;

        while (i < max)
        {
            var o = i < oldLines.Count ? oldLines[i] : null;
            var n = i < newLines.Count ? newLines[i] : null;

            if (!IsChanged(o, n))
            {
                i++;
                continue;
            }

            int start = i;

            while (i < max)
            {
                o = i < oldLines.Count ? oldLines[i] : null;
                n = i < newLines.Count ? newLines[i] : null;

                if (!IsChanged(o, n))
                    break;

                i++;
            }

            int end = i - 1;
            chunks.Add(new DiffChunk(chunkIndex++, start, end));
        }

        return chunks;
    }


    IHtmlContent RenderPieces(IReadOnlyList<DiffPiece> pieces)
    {
        if (pieces is null || pieces.Count == 0) return Html.Raw("");
        var sb = new System.Text.StringBuilder();
        foreach (var p in pieces)
        {
            var txt = (p.Text ?? "").Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
            var cls = p.Type switch { ChangeType.Inserted => "w-ins", ChangeType.Deleted => "w-del", _ => null };
            if (cls is null) sb.Append(txt); else sb.Append($"<span class=\"{cls}\">{txt}</span>");
        }
        return Html.Raw(sb.ToString());
    }

    IHtmlContent RenderLine(DiffPiece? line)
    {
        if (line is null) return Html.Raw("");
        if (line.SubPieces?.Count > 0) return RenderPieces(line.SubPieces);
        var txt = (line.Text ?? "").Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
        return Html.Raw(txt);
    }
}

<h3>
    @Localizer.Format("Page revisions for {0}.",
    $"<a href=\"{@GlobalConfiguration.BasePath}/{@sessionState.PageNavigation}\">{@sessionState.Page.Name}</a>")
</h3>

@if (Model.ThisRevision == null || Model.DiffModel == null)
{
    <div class="card shadow-lg border-warning mt-3">
        <div class="card-header bg-warning text-dark">
            <strong>@Localizer["Revision not found"]</strong>
        </div>
        <div class="card-body">
            <strong>
                @Localizer["The requested page or revision does not exist."]
            </strong>
        </div>
    </div>
}
else
{
    <p>
        <div class="d-flex justify-content-between align-items-center mt-3 mb-3" id="toolbar">
            <div>
                @{
                    string disablePrev = (Model.PreviousRevision ?? 0) == 0 ? "disabled" : "";
                    string disableNext = Model.MostCurrentRevision == Model.ThisRevision ? "disabled" : "";
                }
                @*Left-aligned "toolbar" controls*@
                <a class="btn btn-success me-2" href="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Revisions">@Localizer["View all revisions"]</a>
                <a class="btn btn-success @disablePrev" href="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Compare/@(Model.PreviousRevision ?? 0)">
                    <i class="bi bi-arrow-left"></i>
                    @Localizer["Previous"]
                </a>
                <a class="btn btn-success @disableNext" href="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Compare/@((Model.ThisRevision ?? 0) + 1)">
                    @Localizer["Next"]
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div>
                @*Right-aligned "toolbar" controls*@
            </div>
        </div>
    </p>

    <h6>
        @Localizer.Format("Changes made to this page for revision {0} by {1} on {2}.",
        $"<a href=\"{@GlobalConfiguration.BasePath}/{@sessionState.PageNavigation}/{Model.ThisRevision}\">{(Model.ThisRevision ?? 0)}</a>",
        $"<a href=\"{@GlobalConfiguration.BasePath}/Profile/{Model.ModifiedByUserName}/Public\">{Model.ModifiedByUserName}</a>",
        Model.ModifiedDate)
</h6>

@if (GlobalConfiguration.ShowChangeSummaryWhenEditing && !string.IsNullOrEmpty(Model.ChangeSummary))
    {
        <div class="alert alert-secondary py-2 mb-3">
            <strong>@Localizer["Summary"]:</strong> "@Model.ChangeSummary"
        </div>
    }

    <form method="post" action="@GlobalConfiguration.BasePath/@sessionState.PageNavigation/Compare/@(Model.ThisRevision ?? 0)/Merge">
        @Html.AntiForgeryToken()

        <input type="hidden" id="chunkChoices" name="chunkChoices" value="{}" />

        <div class="diff-wrap">
            <table class="diff-table" id="diffTable">
                <thead class="diff-head">
                    <tr>
                        <th class="ln">Old</th>
                        <th class="gutter"></th>
                        <th class="code">Text</th>
                        <th class="ln">New</th>
                        <th class="gutter"></th>
                        <th class="code">Text</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var oldLines = Model.DiffModel.OldText.Lines;
                        var newLines = Model.DiffModel.NewText.Lines;

                        var count = Math.Max(oldLines.Count, newLines.Count);

                        var chunks = BuildChunks(oldLines, newLines);

                        var chunkByStart = chunks.ToDictionary(c => c.Start, c => c);

                        DiffChunk? FindChunkForRow(int row)
                        {
                            foreach (var c in chunks)
                            {
                                if (row >= c.Start && row <= c.End)
                                {
                                    return c;
                                }
                            }
                            return null;
                        }

                        for (int i = 0; i < count; i++)
                        {
                            // If this row starts a chunk, inject a "chunk header" row.
                            if (chunkByStart.TryGetValue(i, out var chunk))
                            {
                                <tr class="chunk-toolbar" data-chunk="@chunk.Index">
                                    <td colspan="6" class="chunk-toolbar-cell">
                                        <div class="chunk-toolbar-inner">
                                            <span class="badge text-bg-secondary">Chunk @chunk.Index</span>
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="chooseChunk(@chunk.Index, 'old')">Use Old</button>
                                            <button type="button" class="btn btn-sm btn-outline-success" onclick="chooseChunk(@chunk.Index, 'new')">Use New</button>
                                            <span class="small text-muted">Lines @(chunk.Start + 1) - @(chunk.End + 1)</span>
                                        </div>
                                    </td>
                                </tr>
                            }

                            var o = i < oldLines.Count ? oldLines[i] : null;
                            var n = i < newLines.Count ? newLines[i] : null;

                            var lcO = RowClass(o?.Type ?? ChangeType.Imaginary);
                            var lcN = RowClass(n?.Type ?? ChangeType.Imaginary);

                            var rowChunk = FindChunkForRow(i);
                            var chunkAttr = rowChunk is null ? "" : $"data-chunk=\"{rowChunk.Index}\"";

                            <tr class="diff-row" @Html.Raw(chunkAttr)>
                                <td class="ln">@o?.Position</td>
                                <td class="gutter"><div class="bar"></div></td>
                                <td class="@lcO old-cell">@RenderLine(o)</td>

                                <td class="ln">@n?.Position</td>
                                <td class="gutter"><div class="bar"></div></td>
                                <td class="@lcN new-cell">@RenderLine(n)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" onclick="selectAll('old')">Select all Old</button>
            <button type="button" class="btn btn-outline-secondary" onclick="selectAll('new')">Select all New</button>

            <button type="submit" class="btn btn-primary ms-auto">
                Save merged result
            </button>
        </div>
    </form>
}


<script>
    const chunkChoices = {};

    function syncChoices() {
        document.getElementById('chunkChoices').value = JSON.stringify(chunkChoices);
    }

    function chooseChunk(chunkIndex, side) {
        chunkChoices[String(chunkIndex)] = side;
        syncChoices();

        //Update styling for that chunk
        const rows = document.querySelectorAll(`tr.diff-row[data-chunk="${chunkIndex}"]`);
        rows.forEach(r => {
            r.classList.remove('chunk-old-picked', 'chunk-new-picked');
            r.classList.add(side === 'old' ? 'chunk-old-picked' : 'chunk-new-picked');
        });
    }

    function selectAll(side) {
        //Choose for all chunk toolbars present
        const toolbars = document.querySelectorAll('tr.chunk-toolbar[data-chunk]');
        toolbars.forEach(tb => {
            const idx = tb.getAttribute('data-chunk');
            chooseChunk(idx, side);
        });
    }

    // Default behavior: if user doesn't pick, treat as "new"
    // (You can flip this to 'old' if you want.)
    window.addEventListener('DOMContentLoaded', () => {
        const toolbars = document.querySelectorAll('tr.chunk-toolbar[data-chunk]');
        toolbars.forEach(tb => {
            const idx = tb.getAttribute('data-chunk');
            if (chunkChoices[String(idx)] == null) {
                chooseChunk(idx, 'new');
            }
        });
    });
</script>