@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Page
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model TokensViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="card shadow-sm mb-3">
    <div class="card-header d-flex align-items-center gap-2">
        @Localizer["Search Tokens"]
    </div>

    <div class="card-body">
        <div class="d-flex ms-2 mb-1">
            <div class="fw-semibold" style="width:140px;">
                @Localizer["Name"]
            </div>
            <div>
                @Model.PageName
            </div>
        </div>

        <div class="d-flex ms-2 mb-1">
            <div class="fw-semibold" style="width:140px;">
                @Localizer["Navigation"]
            </div>
            <div>
                @Model.Navigation
            </div>
        </div>

        <div class="d-flex ms-2 mb-1">
            <div class="fw-semibold" style="width:140px;">
                @Localizer["Unique tokens"]
            </div>
            <div>
                @Model.Tokens.Count().ToString("N0")
            </div>
        </div>

        <div class="d-flex ms-2 mb-1">
            <div class="fw-semibold" style="width:140px;">
                @Localizer["Total weight"]
            </div>
            <div>
                @Model.Tokens.Sum(o=> o.Weight).ToString("N2")
            </div>
        </div>
    </div>
</div>

<div id="treemap" style="width: 100%; height: 480px; position: abs;"></div>
<div id="tooltip" style="display:none; position:fixed; background:white; border:1px solid #ddd; border-radius:6px; padding:8px 12px; font-size:13px; pointer-events:none; z-index:10;"></div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script>

document.addEventListener('DOMContentLoaded', function () {

    function textColor(weight) {
        const t = (weight - d3.min(tokens, d => d.weight)) /
        (d3.max(tokens, d => d.weight) - d3.min(tokens, d => d.weight));
        return t > 0.6 ? '#E6F1FB' : '#042C53';
    }

    function subTextColor(weight) {
        const t = (weight - d3.min(tokens, d => d.weight)) /
        (d3.max(tokens, d => d.weight) - d3.min(tokens, d => d.weight));
        return t > 0.6 ? '#85B7EB' : '#185FA5';
    }

    const tokens = @Html.Raw(Json.Serialize(Model.Tokens.Select(t => new { token = t.Token, weight = t.Weight })));

    const colorScale = d3.scaleSequential()
        .domain([d3.min(tokens, d => d.weight), d3.max(tokens, d => d.weight)])
        .range(['#B5D4F4', '#0C447C']);

    const container = document.getElementById('treemap');
    const W = container.offsetWidth || 700;
    const H = 480;

    const root = d3.hierarchy({ children: tokens })
        .sum(d => d.weight)
        .sort((a, b) => b.value - a.value);

    d3.treemap().size([W, H]).padding(3).round(true)(root);

    const svg = d3.select('#treemap').append('svg')
        .attr('width', W).attr('height', H).style('display', 'block');

    const tooltip = document.getElementById('tooltip');

    const cell = svg.selectAll('g').data(root.leaves()).join('g')
        .attr('transform', d => `translate(${d.x0},${d.y0})`);

    cell.append('rect')
        .attr('width', d => Math.max(0, d.x1 - d.x0))
        .attr('height', d => Math.max(0, d.y1 - d.y0))
        .attr('rx', 6)
        .attr('fill', d => subTextColor(d.data.weight))
        .attr('stroke', '#fff')
        .attr('stroke-width', 2)
        .style('cursor', 'pointer')
        .on('mousemove', function (event, d) {
            tooltip.style.display = 'block';
            tooltip.style.left = (event.clientX + 12) + 'px';
            tooltip.style.top = (event.clientY - 40) + 'px';
            tooltip.innerHTML = `<span style="font-weight:500">${d.data.token}</span><br><span style="color:#888">weight: ${d.data.weight.toFixed(1)}</span>`;
        })
        .on('mouseleave', function () { tooltip.style.display = 'none'; });

    cell.each(function (d) {
        const w = d.x1 - d.x0;
        const h = d.y1 - d.y0;
        const g = d3.select(this);

        if (w > 40 && h > 28) {
            g.append('text')
                .attr('x', w / 2).attr('y', h / 2 - (h > 44 ? 8 : 0))
                .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
                .attr('fill', d => colorScale(d.data.weight))
                .attr('font-size', Math.min(16, Math.max(11, w / 6)) + 'px')
                .attr('font-weight', '500')
                .text(d.data.token);

            if (h > 44) {
                g.append('text')
                    .attr('x', w / 2).attr('y', h / 2 + 12)
                    .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
                    .attr('fill', '#185FA5').attr('font-size', '11px')
                    .text(d.data.weight.toFixed(1));
            }
        }
    });
});

</script>
}