@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Page
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PageCommentsViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Comments"]
        </h3>
        <div class="mt-1">
            <span class="text-muted">@Localizer["Page"]:</span>
            <a class="text-decoration-none fw-semibold"
                   href="@WikiConfiguration.BasePath/@sessionState.PageNavigation">
                @sessionState.Page.Name
            </a>
        </div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @if (sessionState.IsAuthenticated == true)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header">
                <span class="fw-semibold">
                    <i class="bi bi-chat-left-text me-2"></i>@Localizer["Leave a Comment"]
                </span>
            </div>
            <div class="card-body">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md">
                        <input type="text"
                               name="Comment"
                               id="Comment"
                               class="form-control"
                               placeholder="@Localizer["Type comment..."]" />
                    </div>
                    <div class="col-12 col-md-auto">
                        <button type="submit" value="Post" class="btn btn-primary w-100">
                            <i class="bi bi-send me-1"></i>@Localizer["Post"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <a class="text-decoration-none"
                       href="@WikiConfiguration.BasePath/Identity/Account/Login?returnUrl=@Context.Request.Path.Value">
                    @Localizer["Login to leave a comment"]
                </a>
            </div>
        </div>
    }

    @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")

    @if (Model.Comments.Count > 0)
    {
        <div class="mt-0 d-flex flex-column gap-3">
            @foreach (var h in Model.Comments)
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="mb-3">
                            @Html.Raw(h.Body)
                        </div>

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex align-items-center flex-wrap gap-2 small text-muted">
                                <img src="@WikiConfiguration.BasePath/Profile/@h.UserNavigation/Avatar?Exact=24"
                                     class="rounded-circle"
                                     alt="Avatar"
                                     width="24"
                                     height="24" />

                                @if (WikiConfiguration.EnablePublicProfiles)
                                {
                                    <a href="@WikiConfiguration.BasePath/Profile/@h.UserNavigation/Public"
                                           class="text-decoration-none">
                                        @Html.DisplayTextFor(x => h.UserName)
                                    </a>
                                }
                                else
                                {
                                    <span>
                                        @Html.DisplayTextFor(x => h.UserName)
                                    </span>
                                }

                                <span>•</span>

                                <span>@Html.DisplayTextFor(x => h.CreatedDate)</span>
                            </div>

                            @if (await sessionState.HoldsPermission(WikiPermission.Moderate) || h.UserId == sessionState.Profile?.UserId)
                            {
                                <a href="?Delete=@h.Id"
                                       class="small text-danger text-decoration-none"
                                       onclick="return confirm('@Localizer["Are you sure you want to delete this comment?"]')">
                                    @Localizer["Delete"]
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm mt-3">
            <div class="card-body text-muted">
                <i class="bi bi-chat me-2"></i>
                @Localizer["The page does not have any comments, why don't you add one?"]
            </div>
        </div>
    }

    <div class="mt-3">
        @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
    </div>
}