@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Utility
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model ConfirmActionViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");

    string cardClass = "card shadow-sm mb-3";
    string headerClass = "card-header";
    string headerTextClass = "fw-semibold";
    string yesButtonClass = "btn btn-danger";

    if (string.Equals(Model.Style, "Safe", StringComparison.InvariantCultureIgnoreCase))
    {
        cardClass += " border-success";
        headerClass += " bg-success-subtle border-success";
        headerTextClass += " text-success";
        yesButtonClass = "btn btn-success";
    }
    else if (string.Equals(Model.Style, "Warn", StringComparison.InvariantCultureIgnoreCase))
    {
        cardClass += " border-warning";
        headerClass += " bg-warning-subtle border-warning";
        headerTextClass += " text-dark";
        yesButtonClass = "btn btn-warning";
    }
    else
    {
        cardClass += " border-danger";
        headerClass += " bg-danger-subtle border-danger";
        headerTextClass += " text-danger";
        yesButtonClass = "btn btn-danger";
    }
}

<div class="@cardClass">
    <div class="@headerClass">
        <div class="@headerTextClass">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localizer["Are you sure?"]
        </div>
    </div>

    <div class="card-body">
        <div class="mb-4">
            @Html.Raw(Model.Message)
        </div>

        <form action="@Model.ControllerURL" method="post">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.NoRedirectURL)
            @Html.HiddenFor(m => m.YesRedirectURL)
            @Html.HiddenFor(m => m.Message)
            @Html.HiddenFor(m => m.Style)

            <div class="d-flex flex-wrap gap-2">
                <button type="submit"
                        class="@yesButtonClass"
                        name="UserSelection"
                        value="true">
                    @Localizer["Yes"]
                </button>

                <button type="submit"
                        class="btn btn-success"
                        name="UserSelection"
                        value="false">
                    @Localizer["No"]
                </button>
            </div>
        </form>
    </div>
</div>