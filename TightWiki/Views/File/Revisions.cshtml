@using TightWiki.Models

@using TightWiki.Resources

@model TightWiki.Models.ViewModels.File.PageFileRevisionsViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static["Page File Revisions"]
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["All changes that have been made to the attached file."]
        </div>
    </div>
</div>

@if (Model.Revisions.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="text-nowrap">
                            @SharedLocalizer.Static["Revision"]
                        </th>
                        <th scope="col">
                            @SharedLocalizer.Static["Modified By"]
                        </th>
                        <th scope="col" class="text-nowrap">
                            @SharedLocalizer.Static["Modified Date"]
                        </th>
                        <th scope="col" class="text-nowrap">
                            @SharedLocalizer.Static["Size"]
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var h in Model.Revisions)
                    {
                        <tr>
                            <td class="text-nowrap">
                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/File/Binary/@Model.PageNavigation/@Model.FileNavigation/@h.FileRevision"
                                       target="_blank"
                                       rel="noopener">
                                    @Html.DisplayTextFor(x => h.FileRevision)
                                </a>
                            </td>

                            <td>
                                <a class="text-decoration-none"
                                       href="@GlobalConfiguration.BasePath/Profile/@h.CreatedByUserName/Public">
                                    @Html.DisplayTextFor(x => h.CreatedByUserName)
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @Html.DisplayTextFor(x => h.CreatedDate)
                            </td>

                            <td class="text-nowrap">
                                @Html.DisplayTextFor(x => h.FriendlySize)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-paperclip me-2"></i>
            @SharedLocalizer.Static["This file does not have any revisions."]
        </div>
    </div>
}