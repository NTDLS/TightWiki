@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model DeletedPagesRevisionsViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Deleted Page Revisions"]
        </h3>
        <div class="text-muted">
            @Localizer["Page revisions that have been deleted for the given page. These can be purged or restored."]
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-clock-history me-2"></i>@Localizer["Deleted Revisions"]
        </span>

        @TwConfirmActionHelper.GenerateDangerButton(
            WikiConfiguration.BasePath,
            Localizer["This will permanently purge all deleted page revisions for \"{0}\". Continue?"].Format(Model.Name),
            Localizer["Purge Deleted Revisions"].Value,
            $"/Admin/PurgeDeletedPageRevisions/{Model.PageId}",
            Context.Request.Path.Value)
    </div>
</div>

@if (Model.Revisions.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "Revision")">
                                @Localizer["Revision"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "DeletedDate")">
                                @Localizer["Deleted Date"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "DeletedBy")">
                                @Localizer["Deleted By"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @Localizer["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Revisions)
                    {
                        <tr>
                            <td class="text-nowrap">
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/Admin/DeletedPageRevision/@p.Id/@p.Revision">
                                    @p.Revision
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @p.DeletedDate
                            </td>

                            <td>
                                @p.DeletedByUserName
                            </td>

                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    @TwConfirmActionHelper.GenerateSafeButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will restore the deleted revision. Continue?"].Value,
                                        Localizer["Restore"].Value,
                                        $"/Admin/RestoreDeletedPageRevision/{p.Id}/{p.Revision}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-success btn-sm d-inline-flex align-items-center")

                                    @TwConfirmActionHelper.GenerateDangerButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will permanently delete the specified deleted revision. Continue?"].Value,
                                        Localizer["Purge"].Value,
                                        $"/Admin/PurgeDeletedPageRevision/{p.Id}/{p.Revision}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-danger btn-sm d-inline-flex align-items-center")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-inbox me-2"></i>
            @Localizer["There are no deleted revisions for this page."]
        </div>
    </div>
}