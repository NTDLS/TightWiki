@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model EventLogViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Event Log"]
        </h3>
        <div class="text-muted">
            @Localizer["Server and page event logs"]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-journal-text me-2"></i>@Localizer["Log Entries"]
        </span>

        @TwConfirmActionHelper.GenerateWarnButton(
            WikiConfiguration.BasePath,
            @Localizer["This will permanently purge all event logs. Continue?"].Value,
            @Localizer["Purge Event Log"].Value,
            "/Admin/PurgeEventLog",
            Context.Request.Path.Value)
    </div>

    @if (Model.LogEntries.Count > 0)
    {
        <div class="card-body pb-0">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width: 1%;">@Localizer["Severity"]</th>
                        <th scope="col">@Localizer["Text"]</th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "CreatedDate")">
                                @Localizer["Date/Time"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ex in Model.LogEntries)
                    {
                        string severity = ex.Severity ?? "";
                        string icon = "bi-circle";
                        string badge = "text-secondary";

                        if (severity.Equals("Trace", StringComparison.OrdinalIgnoreCase)
                            || severity.Equals("Debug", StringComparison.OrdinalIgnoreCase)
                            || severity.Equals("None", StringComparison.OrdinalIgnoreCase))
                        {
                            icon = "bi-terminal";
                            badge = "text-secondary";
                        }
                        else if (severity.Equals("Information", StringComparison.OrdinalIgnoreCase))
                        {
                            icon = "bi-info-circle-fill";
                            badge = "text-info";
                        }
                        else if (severity.Equals("Warning", StringComparison.OrdinalIgnoreCase))
                        {
                            icon = "bi-exclamation-triangle-fill";
                            badge = "text-warning";
                        }
                        else if (severity.Equals("Error", StringComparison.OrdinalIgnoreCase))
                        {
                            icon = "bi-x-circle-fill";
                            badge = "text-danger";
                        }
                        else if (severity.Equals("Critical", StringComparison.OrdinalIgnoreCase))
                        {
                            icon = "bi-fire";
                            badge = "text-dark";
                        }

                        <tr>
                            <td class="text-nowrap text-center">
                                <i class="bi @icon @badge me-1"></i>
                            </td>

                            <td>
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/Admin/EventLogEntry/@ex.Id">
                                    @(string.IsNullOrWhiteSpace(ex.Text) ? Localizer["(No text)"].Value : ex.Text)
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @ex.CreatedDate
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    }
    else
    {
        <div class="card-body">
            <div class="text-muted">
                <i class="bi bi-inbox me-2"></i>@Localizer["The event log is empty."]
            </div>
        </div>
    }
</div>