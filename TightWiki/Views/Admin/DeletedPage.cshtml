@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Models
@using TightWiki.Library
@inject ISharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model TightWiki.Models.ViewModels.Page.DeletedPageViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="card shadow-sm border-warning mb-3">
    <div class="card-header bg-warning-subtle border-warning">
        <div class="fw-semibold text-dark">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localizer["Viewing a deleted page"]
        </div>
    </div>

    <div class="card-body">
        <div class="mb-3">
            @Localizer.Format("You are viewing a page which was deleted on {0} by {1}.", Model.DeletedDate, Model.DeletedByUserName)
        </div>

        <div class="d-flex flex-wrap gap-2">
            @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                WikiConfiguration.BasePath,
                Localizer["This will restore the deleted page and all of its history. Continue?"].Value,
                Localizer["Restore This Page"].Value,
                "/Admin/RestoreDeletedPage/" + Model.PageId,
                "/Admin/DeletedPages",
                Context.Request.Path.Value)
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <span class="fw-semibold">
            <i class="bi bi-file-earmark-text me-2"></i>@Localizer["Deleted Page Content"]
        </span>
    </div>
    <div class="card-body">
        @Html.Raw(Model.Body)
    </div>
</div>