@using TightWiki.Library
@using TightWiki.Models

@using TightWiki.Resources

@model TightWiki.Models.ViewModels.Admin.MenuItemViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@SharedLocalizer.Static["Site Menu Item"]</h3>
        <div class="text-muted">@SharedLocalizer.Static["Global configuration for the site menu item."]</div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-list-ul me-2"></i>@SharedLocalizer.Static["Menu Item Editor"]
            </span>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-floppy me-1"></i>@SharedLocalizer.Static["Save"]
                </button>

                @ConfirmActionHelper.GenerateDangerButton(
                    GlobalConfiguration.BasePath,
                    SharedLocalizer.Static["Deleting '{0}' will permanently remove the menu item and you will not be able to revert this action. Continue?"].Format(Model.Name),
                    SharedLocalizer.Static["Delete"].Value,
                    $"/Admin/DeleteMenuItem/{Model.Id}",
                    $"{GlobalConfiguration.BasePath}/Admin/MenuItems",
                    Context.Request.Path.Value)
            </div>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label for="Name" class="form-label fw-semibold">
                        @SharedLocalizer.Static["Name"]
                    </label>
                    @Html.TextBoxFor(m => m.Name, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Required"].Value
                    })
                    <div class="text-danger small">
                        @Html.ValidationMessageFor(m => m.Name)
                    </div>
                </div>

                <div class="col-12">
                    <label for="Link" class="form-label fw-semibold">
                        @SharedLocalizer.Static["Hyperlink"]
                    </label>
                    @Html.TextBoxFor(m => m.Link, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Required"].Value
                    })
                    <div class="form-text">
                        @SharedLocalizer.Static["Enter an internal path or external URL."]
                    </div>
                    <div class="text-danger small">
                        @Html.ValidationMessageFor(m => m.Link)
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Ordinal" class="form-label fw-semibold">
                        @SharedLocalizer.Static["Ordinal"]
                    </label>
                    @Html.TextBoxFor(m => m.Ordinal, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Required"].Value,
                        type = "number",
                        min = "0"
                    })
                    <div class="form-text">
                        @SharedLocalizer.Static["Lower numbers appear first."]
                    </div>
                    <div class="text-danger small">
                        @Html.ValidationMessageFor(m => m.Ordinal)
                    </div>
                </div>
            </div>
        </div>
    </div>
}