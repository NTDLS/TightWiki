@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Attributes.Functions
@using TightWiki.Plugin.Attributes.Handlers
@using TightWiki.Plugin.Interfaces
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PluginHandlerViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Plugin"]</h3>
        <div class="text-muted">
            @Localizer["Global configuration for plugin handler."]
        </div>
    </div>
</div>

@if (Model.Handler != null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center gap-2">
            <i class="bi bi-code-slash text-muted" data-bs-toggle="tooltip" title="Markup handler"></i>
            @Localizer["Plugin Handler"]
        </div>

        <div class="card-body">
            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Name"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Name
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Description"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Description
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Precedence"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Precedence
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["First Chance?"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.IsFirstChance
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Wiki Lite?"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.IsLitePermissiable
                </div>
            </div>
        </div>
    </div>

    @if (Model.Handler?.ExpressionAttributes.Count > 0)
    {
        <div class="card shadow-sm mt-2">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-braces"></i>
                <span class="fw-semibold">@Localizer["Expressions"]</span>
            </div>

            <div class="card-body">
                <ul class="list-group list-group-flush">
                    @foreach (var exprAttr in Model.Handler.ExpressionAttributes)
                    {
                        <li class="list-group-item">
                            <div class="d-flex align-items-center justify-content-between gap-2">
                                <code class="bg-light border rounded px-2 py-1 small text-break flex-grow-1">
                                    @exprAttr.Pattern
                                </code>

                                @if (exprAttr.Multiline)
                                {
                                    <span class="badge text-bg-primary">MULTILINE</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">SINGLE</span>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    }
}

