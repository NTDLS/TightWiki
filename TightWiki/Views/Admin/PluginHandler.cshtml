@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Attributes.Functions
@using TightWiki.Plugin.Attributes.Handlers
@using TightWiki.Plugin.Interfaces
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PluginHandlerViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Plugin"]</h3>
        <div class="text-muted">
            @Localizer["Global configuration for plugin handler."]
        </div>
    </div>
</div>

@if (Model.Handler != null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center gap-2">
            @switch (Model.Handler?.HandlerAttribute.GetType())
            {
                case Type t when t == typeof(TwProcessingInstructionFunctionPluginAttribute):
                    <i class="bi bi-cpu text-primary" data-bs-toggle="tooltip" title="Processing function"></i>
                    break;
                case Type t when t == typeof(TwScopeFunctionPluginAttribute):
                    <i class="bi bi-bounding-box text-primary" data-bs-toggle="tooltip" title="Scope function"></i>
                    break;
                case Type t when t == typeof(TwStandardFunctionPluginAttribute):
                    <i class="bi bi-gear text-primary" data-bs-toggle="tooltip" title="Standard function"></i>
                    break;
                case Type t when t == typeof(TwMarkupPluginHandlerAttribute):
                    <i class="bi bi-code-slash text-muted" data-bs-toggle="tooltip" title="Markup handler"></i>
                    break;
                default:
                    <i class="bi bi-question-circle" data-bs-toggle="tooltip" title="Unknown type"></i>
                    break;
            }
            @Localizer["Plugin Handler"]
        </div>

        <div class="card-body">
            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Name"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Name
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Description"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Description
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Precedence"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Precedence
                </div>
            </div>

@*             <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Demarcation"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.Demarcation
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Is First Chance?"]
                </div>
                <div>
                    @Model.Handler?.HandlerAttribute.IsFirstChance
                </div>
            </div> *@

            @if (Model.Handler != null)
            {
                <div class="mt-3 pt-2 border-top">
                    <div class="small text-body-secondary mb-1">
                        <i class="bi bi-code-slash me-1"></i>
                        @Localizer["Handler Signature"]
                    </div>

                    <div class="font-monospace px-2 py-1">
                        
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model.Handler != null)
    {
        int skipCount;
        if (Model.Handler.HandlerAttribute is TwScopeFunctionPluginAttribute)
        {
            skipCount = 2; //State and body.
        }
        else
        {
            skipCount = 1; //State.
        }

        @if (Model.Handler.Parameters.Skip(skipCount).Count() > 0)
        {

            <div class="card shadow-sm mt-2">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-gear"></i>
                    <span class="fw-semibold">@Localizer["Parameters"]</span>
                </div>

                <div class="card-body">
                    
                </div>
            </div>
        }
    }

}
