@model TightWiki.Models.ViewModels.Admin.PageRevisionsViewModel
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki
@using TightWiki.Library
@using TightWiki.Models
@inject ISharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Page Revisions"]
        </h3>
        <div class="text-muted">
            @Localizer["All changes that have been made to the page."]
        </div>
        <div class="mt-1">
            <span class="text-muted">@Localizer["Page"]:</span>
            <a class="text-decoration-none fw-semibold"
                   href="@WikiConfiguration.BasePath/@sessionState.PageNavigation">
                @sessionState.Page.Name
            </a>
        </div>
    </div>
</div>

@if (Model.Revisions.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Revision")">
                                @Localizer["Revision"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "ModifiedBy")">
                                @Localizer["Modified By"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "ModifiedDate")">
                                @Localizer["Modified Date"]
                            </a>
                        </th>
                        @if (WikiConfiguration.ShowChangeSummaryWhenEditing)
                        {
                            <th scope="col">
                                @Localizer["Summary"]
                            </th>
                        }
                        <th scope="col">
                            @Localizer["Analysis"]
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @Localizer["Action"]
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var h in Model.Revisions)
                    {
                        <tr>
                            <td class="text-nowrap">
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/@h.Revision"
                                       target="_blank"
                                       rel="noopener">
                                    @Html.DisplayTextFor(x => h.Revision)
                                </a>
                            </td>

                            <td>
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/Profile/@h.ModifiedByUserName/Public">
                                    @Html.DisplayTextFor(x => h.ModifiedByUserName)
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @Html.DisplayTextFor(x => h.ModifiedDate)
                            </td>

                            @if (WikiConfiguration.ShowChangeSummaryWhenEditing)
                            {
                                <td>
                                    <a class="text-decoration-none"
                                           href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/Compare/@h.Revision">
                                        @Html.DisplayTextFor(x => h.ChangeSummary)
                                    </a>
                                </td>
                            }

                            <td>
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/@sessionState.PageNavigation/Compare/@h.Revision">
                                    @Html.DisplayTextFor(x => h.ChangeAnalysis)
                                </a>
                            </td>

                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["Reverting {0} from revision {1} to {2} will rollback {3} changes.<br />Reverting does not mean that changes will be lost however, the revert process will create a new revision with the reverted changes.<br /><br />Are you sure you want to continue?<br /><br />"]
                                            .Format(h.Name, h.HighestRevision, h.Revision, h.HigherRevisionCount),
                                        Localizer["Revert"].Value,
                                        $"/Admin/RevertPageRevision/{h.Navigation}/{h.Revision}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-warning btn-sm d-inline-flex align-items-center")

                                    @TightWiki.Library.ConfirmActionHelper.GenerateDangerButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["Deleting revision {0} of \"{1}\" will move the page revision to the deletion queue. This action can only be undone by an administrator or moderator. Continue?"]
                                            .Format(h.Revision, h.Name),
                                        Localizer["Delete"].Value,
                                        $"/Admin/DeletePageRevision/{h.Navigation}/{h.Revision}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-danger btn-sm d-inline-flex align-items-center")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-clock-history me-2"></i>
            @Localizer["The selected page does not have any revisions."]
        </div>
    </div>
}