@model TightWiki.Models.ViewModels.Admin.PageCompilationStatisticsViewModel
@using TightWiki.Library
@using TightWiki.Models

@using TightWiki.Resources

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static["Compilations"]
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["The compilation statistics for all wiki page operations."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-bar-chart-line me-2"></i>@SharedLocalizer.Static["Compilation Statistics"]
        </span>

        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
            GlobalConfiguration.BasePath,
            SharedLocalizer.Static["Purging the page compilation statistics will delete all of the stored compilation statistics for all pages. Continue?"].Value,
            SharedLocalizer.Static["Purge Compilation Statistics"].Value,
            "/Admin/PurgeCompilationStatistics",
            Context.Request.Path.Value)
    </div>

    @if (Model.Statistics.Count > 0)
    {
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Namespace")">
                                @SharedLocalizer.Static["Name"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "CreatedDate")">
                                @SharedLocalizer.Static["Date/Time"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Compilations")">
                                @SharedLocalizer.Static["Compilations"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgBuildTimeMs")">
                                @SharedLocalizer.Static["Duration"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgWikiMatches")">
                                @SharedLocalizer.Static["Matches"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "TotalErrorCount")">
                                @SharedLocalizer.Static["Errors"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgOutgoingLinkCount")">
                                @SharedLocalizer.Static["Links"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgTagCount")">
                                @SharedLocalizer.Static["Tags"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgRawBodySize")">
                                @SharedLocalizer.Static["Raw Size"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AvgWikifiedBodySize")">
                                @SharedLocalizer.Static["Wikified Size"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stat in Model.Statistics)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(stat.Namespace))
                                {
                                    <a class="text-decoration-none text-muted"
                                           href="@GlobalConfiguration.BasePath/Admin/Namespace/@stat.Namespace">
                                        @stat.Namespace
                                    </a>
                                    <span class="text-muted"> :: </span>
                                }

                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/@stat.Navigation">
                                    @stat.Title
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @stat.LatestBuild
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.Compilations.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.AvgBuildTimeMs.ToString("N0")<span class="text-muted">ms</span>
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.AvgWikiMatches.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @if (stat.TotalErrorCount > 0)
                                {
                                    <span class="badge border border-danger text-danger bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-exclamation-triangle me-1"></i>@stat.TotalErrorCount.ToString("N0")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.AvgOutgoingLinkCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.AvgTagCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @NTDLS.Helpers.Formatters.FileSize((long)stat.AvgRawBodySize)
                            </td>

                            <td class="text-end text-nowrap">
                                @NTDLS.Helpers.Formatters.FileSize((long)stat.AvgWikifiedBodySize)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-bar-chart me-2"></i>
            @SharedLocalizer.Static["There are no compilation statistics available."]
        </div>
    }
</div>