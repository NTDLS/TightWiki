@model TightWiki.Models.ViewModels.Admin.PageCompilationStatisticsViewModel
@using NTDLS.Helpers
@using TightWiki.Library
@using TightWiki.Models
@inject ISharedLocalizationText Localizer

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Compilations"]
        </h3>
        <div class="text-muted">
            @Localizer["The compilation statistics for all wiki page operations."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-bar-chart-line me-2"></i>@Localizer["Compilation Statistics"]
        </span>

        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
            GlobalConfiguration.BasePath,
            Localizer["Purging the page compilation statistics will delete all of the stored compilation statistics for all pages. Continue?"].Value,
            Localizer["Purge Compilation Statistics"].Value,
            "/Admin/PurgeCompilationStatistics",
            Context.Request.Path.Value)
    </div>

    @if (Model.Statistics.Count > 0)
    {
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
   
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Name")">
                                @Localizer["Name"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastCompileDateTime")">
                                @Localizer["Last Compile"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastErrorCount")">
                                @Localizer["Errors"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "TotalCompilationCount")">
                                @Localizer["Compilations"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastWikifyTimeMs")">
                                @Localizer["Build Duration"] <span class="text-muted">(<span class="text-muted">ms</span>)</span>
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastMatchCount")">
                                @Localizer["Wiki Matches"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastOutgoingLinkCount")">
                                @Localizer["Outgoing Links"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastTagCount")">
                                @Localizer["Tags"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastBodySize")">
                                @Localizer["Raw Doby"]<span class="text-muted">@Localizer["bytes"]</span>
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastProcessedBodySize")">
                                @Localizer["Processed Body"]<span class="text-muted">@Localizer["bytes"]</span>
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stat in Model.Statistics)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(stat.Namespace))
                                {
                                    <a class="text-decoration-none text-muted"
                                           href="@GlobalConfiguration.BasePath/Admin/Namespace/@stat.Namespace">
                                        @stat.Namespace
                                    </a>
                                    <span class="text-muted"> :: </span>
                                }

                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/@stat.Navigation">
                                    @stat.Title
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @stat.LastCompileDateTime
                            </td>

                            <td class="text-end text-nowrap">
                                @if (stat.LastErrorCount > 0)
                                {
                                    <span class="badge border border-danger text-danger bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-exclamation-triangle me-1"></i>@stat.LastErrorCount.ToString("N0")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.TotalCompilationCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastWikifyTimeMs.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastMatchCount.ToString("N0")
                            </td>
                                
                            <td class="text-end text-nowrap">
                                @stat.LastOutgoingLinkCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastTagCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @Formatters.FileSize((long)stat.LastBodySize)
                            </td>

                            <td class="text-end text-nowrap">
                                @Formatters.FileSize((long)stat.LastProcessedBodySize)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-bar-chart me-2"></i>
            @Localizer["There are no compilation statistics available."]
        </div>
    }
</div>