@using TightWiki
@using TightWiki.Models
@using TightWiki.Library
@inject ISharedLocalizationText Localizer
@inject TightWikiConfiguration WikiConfiguration

@model TightWiki.Models.ViewModels.Admin.PageModerateViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Page Moderate"]
        </h3>
        <div class="text-muted">
            @Localizer["Browse pages marked with various processing instructions to see what is in draft, pending deletion, protected, etc."]
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header">
        <span class="fw-semibold">
            <i class="bi bi-funnel me-2"></i>@Localizer["Filter"]
        </span>
    </div>

    <div class="card-body">
        @using (Html.BeginForm(FormMethod.Get))
        {
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md">
                    @Html.DropDownListFor(
                        m => m.Instruction,
                        new SelectList(Model.Instructions),
                        Localizer["Select an instruction"].Value,
                        new { @class = "form-select", id = "instructionDropdown" })
                </div>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-clockwise me-1"></i>@Localizer["Refresh"]
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.Pages.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">@Localizer["Name"]</th>
                        <th scope="col" class="text-nowrap">@Localizer["Revision"]</th>
                        <th scope="col">@Localizer["Modified By"]</th>
                        <th scope="col" class="text-nowrap">@Localizer["Modified Date"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Pages)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@p.Navigation">
                                    @p.Name
                                </a>
                            </td>

                            <td class="text-nowrap">
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/@p.Navigation/Revisions">
                                    @p.Revision
                                </a>
                            </td>

                            <td>
                                @p.ModifiedByUserName
                            </td>

                            <td class="text-nowrap text-muted">
                                @p.ModifiedDate
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-filter-circle me-2"></i>
            @Localizer["There are no pages which contain the selected processing instruction."]
        </div>
    </div>
}

<script>
    document.getElementById("instructionDropdown")?.addEventListener("change", function () {
        this.form.submit();
    });
</script>