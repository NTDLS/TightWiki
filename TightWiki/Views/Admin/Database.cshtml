@using TightWiki
@using TightWiki.Library
@using TightWiki.Models
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@inject ISharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model TightWiki.Models.ViewModels.Admin.DatabaseViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Database"]
        </h3>
        <div class="text-muted">
            @Localizer["Various utilities to assist in management of the SQLite database."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <span class="fw-semibold">
            <i class="bi bi-database me-2"></i>@Localizer["Database Utilities"]
        </span>
    </div>

    @if (Model.Info.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            @Localizer["Name"]
                        </th>
                        <th scope="col" class="text-nowrap">
                            @Localizer["Version"]
                        </th>
                        <th scope="col" class="text-nowrap">
                            @Localizer["Size"]
                        </th>
                        <th scope="col">
                            @Localizer["Action"]
                        </th>
                        <th scope="col">
                            @Localizer["Restore"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var info in Model.Info)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @info.Name
                            </td>

                            <td class="text-nowrap text-muted">
                                @info.Version
                            </td>

                            <td class="text-nowrap">
                                @NTDLS.Helpers.Formatters.FileSize((long)info.DatabaseSize)
                            </td>

                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will optimize the database indexes and structure. Continue?"].Value,
                                        Localizer["Optimize"].Value,
                                        $"/Admin/Database/Optimize/{info.Name}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-primary btn-sm d-inline-flex align-items-center")

                                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will remove empty space from the database, which can free space if a lot of data has been deleted. Continue?"].Value,
                                        Localizer["Vacuum"].Value,
                                        $"/Admin/Database/Vacuum/{info.Name}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-primary btn-sm d-inline-flex align-items-center")

                                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will check the database integrity and validate all foreign keys. Continue?"].Value,
                                        Localizer["Verify"].Value,
                                        $"/Admin/Database/Verify/{info.Name}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-primary btn-sm d-inline-flex align-items-center")
                                </div>
                            </td>

                            <td>
                                <div class="d-flex flex-wrap gap-2">

                                    @if (info.Name == "Config")
                                    {
                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will merge in all default configuration, but will not overwrite any of your currently configured settings. Continue?"].Value,
                                            Localizer["Configuration"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.Configurations}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")

                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will restore all default themes, overwriting any customizations you may have made in the database. Continue?"].Value,
                                            Localizer["Themes"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.Themes}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")
                                    }
                                    else if (info.Name == "Pages")
                                    {
                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will restore all Wiki Help namespace pages. Continue?"].Value,
                                            Localizer["Wiki Help Pages"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.WikiHelpPages}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")

                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will restore all built-in namespace pages, overwriting any customizations you may have made. Continue?"].Value,
                                            Localizer["Built-in Pages"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.WikiBuiltinPages}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")

                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will restore all Include namespace pages. Continue?"].Value,
                                            Localizer["Include Pages"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.WikiIncludePages}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")

                                        @TightWiki.Library.ConfirmActionHelper.GenerateWarnButton(
                                            WikiConfiguration.BasePath,
                                            Localizer["This will restore all Feature Templates, overwriting any customizations you may have made. Continue?"].Value,
                                            Localizer["Feature Templates"].Value,
                                            $"/Admin/Database/Restore/{WikiDefaultDataType.FeatureTemplates}",
                                            Context.Request.Path.Value,
                                            @class: "btn btn-warning text-dark btn-sm d-inline-flex align-items-center")
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-database-x me-2"></i>
            @Localizer["No database information is available."]
        </div>
    }
</div>