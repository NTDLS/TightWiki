@using TightWiki.Models
@using static TightWiki.Library.Constants
@inject IViewLocalizer Localizer
@model TightWiki.Models.ViewModels.Admin.DatabaseViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<h3>
    @Localizer["Database"]
</h3>

<p>
    @Localizer["Various utilities to assist in management of the SQLite database."]
</p>


<table class="table fixedTable100 table-striped" border="0" width="100%" cellspacing="0" cellpadding="0">
    <thead>
        <tr>
            <td><strong>@Localizer["Name"]</strong></td>
            <td><strong>@Localizer["Version"]</strong></td>
            <td><strong>@Localizer["Size"]</strong></td>
            <td><strong>@Localizer["Action"]</strong></td>
        </tr>
    </thead>

    @foreach (var info in Model.Info)
    {
        <tr>
            <td>@info.Name</td>
            <td>@info.Version</td>
            <td>@NTDLS.Helpers.Formatters.FileSize((long)info.DatabaseSize)</td>
            <td>
                @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                    Localizer["This will optimize the database indexes and structure. Continue?"].Value,
                    Localizer["Optimize"].Value, $"/Admin/Database/Optimize/{info.Name}", Context.Request.Path.Value, @class: "btn-thin rounded-0")

                @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                    Localizer["This will remove empty space from the database, which can free space if a lot of data has been deleted. Continue?"].Value,
                    Localizer["Vacuum"].Value, $"/Admin/Database/Vacuum/{info.Name}", Context.Request.Path.Value, @class: "btn-thin rounded-0")

                @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                    Localizer["This will check the database integrity and validate all foreign keys. Continue?"].Value,
                    Localizer["Verify"].Value, $"/Admin/Database/Verify/{info.Name}", Context.Request.Path.Value, @class: "btn-thin rounded-0")
   
                @if (info.Name == "Config")
                {
                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will merge in all default configuration, but will not overwrite any of your currently configured settings. Continue?"].Value,
                        Localizer["Restore Configuration"].Value, $"/Admin/Database/Restore/{DefaultDataType.Configurations}", Context.Request.Path.Value, @class: "btn-thin rounded-0 me-2")

                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will restore all default themes, overwriting any customizations you may have made in the database. Continue?"].Value,
                        Localizer["Themes"].Value, $"/Admin/Database/Restore/{DefaultDataType.Themes}", Context.Request.Path.Value, @class: "btn-thin rounded-0")
                }
                else if (info.Name == "Pages")
                {
                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will restore all Wiki Help namespace pages. Continue?"].Value,
                        Localizer["Wiki Help Pages"].Value, $"/Admin/Database/Restore/{DefaultDataType.WikiHelpPages}", Context.Request.Path.Value, @class: "btn-thin rounded-0 me-2")

                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will restore all built-in namespace pages, overwriting any customizations you may have made. Continue?"].Value,
                        Localizer["Built-in Pages"].Value, $"/Admin/Database/Restore/{DefaultDataType.WikiBuiltinPages}", Context.Request.Path.Value, @class: "btn-thin rounded-0 me-2")

                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will restore all Include namespace pages. Continue?"].Value,
                        Localizer["Include Pages"].Value, $"/Admin/Database/Restore/{DefaultDataType.WikiIncludePages}", Context.Request.Path.Value, @class: "btn-thin rounded-0 me-2")

                    @TightWiki.Library.ConfirmActionHelper.GenerateSafeButton(GlobalConfiguration.BasePath,
                        Localizer["This will restore all Feature Templates, overwriting any customizations you may have made. Continue?"].Value,
                        Localizer["Feature Templates"].Value, $"/Admin/Database/Restore/{DefaultDataType.FeatureTemplates}", Context.Request.Path.Value, @class: "btn-thin rounded-0")
                    
                }
            </td>
        </tr>
    }
</table>
