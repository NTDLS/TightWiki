@model TightWiki.Models.ViewModels.Admin.MenuItemsViewModel
@using TightWiki.Library
@using TightWiki.Models
@inject ISharedLocalizationText Localizer

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Site Menu Items"]
        </h3>
        <div class="text-muted">
            @Localizer["Global configuration for the site menu."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-list-ul me-2"></i>@Localizer["Menu Configuration"]
        </span>

        <a class="btn btn-success"
               href="@GlobalConfiguration.BasePath/Admin/MenuItem">
            <i class="bi bi-plus-circle me-1"></i>@Localizer["Add new item"]
        </a>
    </div>

    @if (Model.Items.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Name")">
                                @Localizer["Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Link")">
                                @Localizer["Hyperlink"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Ordinal")">
                                @Localizer["Ordinal"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/Admin/MenuItem/@item.Id">
                                    @item.Name
                                </a>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.Link))
                                {
                                    <code class="text-break">@item.Link</code>
                                }
                                else
                                {
                                    <span class="text-muted">@Localizer["(No link)"]</span>
                                }
                            </td>

                            <td class="text-nowrap text-muted">
                                @item.Ordinal
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-list me-2"></i>
            @Localizer["There are no menu items configured."]
        </div>
    }
</div>