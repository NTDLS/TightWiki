@model TightWiki.Models.ViewModels.Admin.OrphanedPageAttachmentsViewModel
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki
@using TightWiki.Library
@using TightWiki.Models
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Orphaned Page Attachments"]
        </h3>
        <div class="text-muted">
            @Localizer["These are all of the page attachments that are no longer attached to any page revision."]
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-paperclip me-2"></i>@Localizer["Orphaned Attachments"]
        </span>

        @TightWiki.Library.ConfirmActionHelper.GenerateDangerButton(
            WikiConfiguration.BasePath,
            Localizer["This will permanently purge all orphaned page attachments. Continue?"].Value,
            Localizer["Purge Orphaned Attachments"].Value,
            "/Admin/PurgeOrphanedAttachments",
            Context.Request.Path.Value)
    </div>
</div>

@if (Model.Files.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Page")">
                                @Localizer["Page"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "File")">
                                @Localizer["File"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap" style="width: 1%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Size")">
                                @Localizer["Size"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Revision")">
                                @Localizer["Revision"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @Localizer["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Files)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(p.Namespace))
                                {
                                    <a class="text-decoration-none text-muted"
                                           href="@WikiConfiguration.BasePath/Admin/Namespace/@p.Namespace">
                                        @p.Namespace
                                    </a>
                                    <span class="text-muted"> :: </span>
                                }

                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@p.PageNavigation">
                                    @p.PageTitle
                                </a>
                            </td>

                            <td>
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/File/Binary/@p.PageNavigation/@p.FileNavigation/@p.FileRevision">
                                    @p.FileName
                                </a>
                            </td>

                            <td class="text-end text-nowrap">
                                @NTDLS.Helpers.Formatters.FileSize((long)p.Size)
                            </td>

                            <td class="text-nowrap text-muted">
                                @p.FileRevision
                            </td>

                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    @TightWiki.Library.ConfirmActionHelper.GenerateDangerButton(
                                        WikiConfiguration.BasePath,
                                        Localizer["This will permanently delete the specified attachment. Continue?"].Value,
                                        Localizer["Delete"].Value,
                                        $"/Admin/PurgeOrphanedAttachment/{p.PageFileId}/{p.FileRevision}",
                                        Context.Request.Path.Value,
                                        @class: "btn btn-outline-danger btn-sm d-inline-flex align-items-center")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-check-circle me-2"></i>
            @Localizer["There are no orphaned page attachments."]
        </div>
    </div>
}