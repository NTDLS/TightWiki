@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model EmojisViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Emojis"]
        </h3>
        <div class="text-muted">
            @Localizer["Global configuration for Emojis."]
        </div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Get))
{
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-emoji-smile me-2"></i>@Localizer["Emoji Management"]
            </span>

            <a class="btn btn-success"
                   href="@WikiConfiguration.BasePath/Admin/AddEmoji">
                <i class="bi bi-plus-circle me-1"></i>@Localizer["Add new emoji"]
            </a>
        </div>

        <div class="card-body">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md">
                    @Html.TextBoxFor(x => x.SearchString, new
                    {
                        @class = "form-control",
                        placeholder = Localizer["Search emojis..."].Value
                    })
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>@Localizer["Search"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Emojis.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "Name")">
                                @Localizer["Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "Shortcut")">
                                @Localizer["Shortcut"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @Localizer["Image"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emoji in Model.Emojis)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/Admin/Emoji/@emoji.Name">
                                    @emoji.Name
                                </a>
                            </td>
                            <td>
                                <code>@emoji.Shortcut</code>
                            </td>
                            <td class="text-center">
                                <img src="@WikiConfiguration.BasePath/File/Emoji/@emoji.Name"
                                     alt="@emoji.Name"
                                     class="img-thumbnail p-1"
                                     style="max-width: 40px; max-height: 40px;" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-emoji-frown me-2"></i>
            @Localizer["Either there are no emojis configured or your search criteria returned no results."]
        </div>
    </div>
}

<script>
    window.onload = function () {
        document.getElementById("SearchString")?.focus();
    }
</script>