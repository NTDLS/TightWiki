@model TightWiki.Models.ViewModels.Admin.PagesViewModel
@using TightWiki.Library
@using TightWiki.Models

@using TightWiki.Resources

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static["Pages"]
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["All pages contained in the wiki."]
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-file-earmark-text me-2"></i>@SharedLocalizer.Static["Page Administration"]
        </span>

        <div class="d-flex flex-wrap gap-2">
            @ConfirmActionHelper.GenerateWarnButton(
                GlobalConfiguration.BasePath,
                SharedLocalizer.Static["This will rebuild all pages in the wiki. This could take some time! Continue?"].Value,
                SharedLocalizer.Static["Rebuild All Pages"].Value,
                "/Admin/RebuildAllPages",
                Context.Request.Path.Value,
                @class: "btn btn-outline-warning btn-sm d-inline-flex align-items-center")

            @ConfirmActionHelper.GenerateWarnButton(
                GlobalConfiguration.BasePath,
                SharedLocalizer.Static["This will compile all pages in the wiki and store them in cache. This could take some time! Continue?"].Value,
                SharedLocalizer.Static["Pre-Cache All Pages"].Value,
                "/Admin/PreCacheAllPages",
                Context.Request.Path.Value,
                @class: "btn btn-outline-primary btn-sm d-inline-flex align-items-center")

            @ConfirmActionHelper.GenerateDangerButton(
                GlobalConfiguration.BasePath,
                SharedLocalizer.Static["Truncating the page revisions will delete all the revision history for all pages and page attachments. This will leave only the most current revision of all objects. This is generally considered a big deal! Continue?"].Value,
                SharedLocalizer.Static["Truncate Page Revisions"].Value,
                "/Admin/TruncatePageRevisions",
                Context.Request.Path.Value,
                @class: "btn btn-outline-danger btn-sm d-inline-flex align-items-center")
        </div>
    </div>

    <div class="card-body">
        @using (Html.BeginForm(FormMethod.Get))
        {
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md">
                    @Html.TextBoxFor(x => x.SearchString, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Search pages..."].Value
                    })
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>@SharedLocalizer.Static["Search"]
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.Pages.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Name")">
                                @SharedLocalizer.Static["Name"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Revision")">
                                @SharedLocalizer.Static["Revision"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap text-center" style="width: 1%;">
                            @SharedLocalizer.Static["Deleted Revisions"]
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "ModifiedBy")">
                                @SharedLocalizer.Static["Modified By"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "ModifiedDate")">
                                @SharedLocalizer.Static["Modified Date"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @SharedLocalizer.Static["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Pages)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(p.Namespace))
                                {
                                    <a class="text-decoration-none text-muted"
                                           href="@GlobalConfiguration.BasePath/Admin/Namespace/@p.Namespace">
                                        @p.Namespace
                                    </a>
                                    <span class="text-muted"> :: </span>
                                }

                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/@p.Navigation">
                                    @p.Title
                                </a>
                            </td>

                            <td class="text-nowrap">
                                <a class="text-decoration-none"
                                       href="@GlobalConfiguration.BasePath/Admin/PageRevisions/@p.Navigation">
                                    @p.Revision
                                </a>
                            </td>

                            <td class="text-center text-nowrap">
                                <a class="text-decoration-none"
                                       href="@GlobalConfiguration.BasePath/Admin/DeletedPageRevisions/@p.Id">
                                    @p.DeletedRevisionCount
                                </a>
                            </td>

                            <td>
                                @p.ModifiedByUserName
                            </td>

                            <td class="text-nowrap text-muted">
                                @p.ModifiedDate
                            </td>

                            <td class="text-nowrap">
                                <div class="d-flex flex-wrap gap-2">
                                    @ConfirmActionHelper.GenerateDangerButton(
                                        GlobalConfiguration.BasePath,
                                        SharedLocalizer.Static["Deleting '{0}' will move the page, all {1} revisions and associated file attachments to the deletion queue. This action can only be undone by an administrator or moderator. Continue?"].Format(p.Name, p.Revision),
                                        SharedLocalizer.Static["Delete"].Value,
                                        "/Admin/DeletePage/" + p.Id,
                                        Context.Request.Path.Value,
                                        @class: "btn btn-outline-danger btn-sm d-inline-flex align-items-center")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-inbox me-2"></i>
            @SharedLocalizer.Static["Either there are no pages or your search criteria returned no results."]
        </div>
    </div>
}

<script>
    window.onload = function () {
        document.getElementById("SearchString")?.focus();
    }
</script>