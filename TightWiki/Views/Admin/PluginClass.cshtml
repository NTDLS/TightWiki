@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Attributes.Functions
@using TightWiki.Plugin.Attributes.Handlers
@using TightWiki.Plugin.Interfaces
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PluginClassViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Plugin"]</h3>
        <div class="text-muted">
            @Localizer["Global configuration for plugin class."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-plug me-2"></i>@Localizer["Plugin Class"]
        </span>
    </div>

    <div class="col-12 row align-items-center">
        <label class="col-auto col-form-label fw-semibold ms-2 pe-2">
            @Localizer["Name"]
        </label>
        <div class="col-auto">
            <div class="form-control-plaintext p-0">
                @Model.Plugin?.Name
            </div>
        </div>
    </div>

    <div class="col-12 row align-items-center">
        <label class="col-auto col-form-label fw-semibold ms-2 pe-2">
            @Localizer["Description"]
        </label>
        <div class="col-auto">
            <div class="form-control-plaintext p-0">
                @Model.Plugin?.Description
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    @if (Model.Contents.Count > 0)
    {
        <table class="table table-striped table-hover align-middle mt-3 mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-nowrap text-center align-middle">
                        @Localizer["Type"]
                    </th>
                    <th scope="col">
                        @Localizer["Name"]
                    </th>
                    <th scope="col">
                        @Localizer["Description"]
                    </th>
                    <th scope="col">
                        @Localizer["Precedence"]
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var content in Model.Contents)
                {
                    @if (Model.Plugin == null)
                    {
                        continue;
                    }

                    <tr>
                        <td class="text-nowrap text-center align-middle">
                            @if (content.Type == typeof(TwPostProcessingInstructionFunctionPluginAttribute))
                            {
                                <i class="bi bi-cpu-fill text-primary" data-bs-toggle="tooltip" title="Post-processing function"></i>
                            }
                            else if (content.Type == typeof(TwProcessingInstructionFunctionPluginAttribute))
                            {
                                <i class="bi bi-cpu text-primary" data-bs-toggle="tooltip" title="Processing function"></i>
                            }
                            else if (content.Type == typeof(TwScopeFunctionPluginAttribute))
                            {
                                <i class="bi bi-bounding-box text-primary" data-bs-toggle="tooltip" title="Scope function"></i>
                            }
                            else if (content.Type == typeof(TwStandardFunctionPluginAttribute))
                            {
                                <i class="bi bi-gear text-primary" data-bs-toggle="tooltip" title="Standard function"></i>
                            }
                            else if (content.Type == typeof(TwMarkupPluginHandlerAttribute))
                            {
                                <i class="bi bi-code-slash text-muted" data-bs-toggle="tooltip" title="Markup handler"></i>
                            }
                            else if (content.Type == typeof(TwHeadingPluginHandlerAttribute))
                            {
                                <i class="bi bi-type-h1 text-muted" data-bs-toggle="tooltip" title="Heading handler"></i>
                            }
                            else if (content.Type == typeof(TwCommentPluginHandlerAttribute))
                            {
                                <i class="bi bi-chat-left-dots text-muted" data-bs-toggle="tooltip" title="Comment handler"></i>
                            }
                            else if (content.Type == typeof(TwCompletionPluginHandlerAttribute))
                            {
                                <i class="bi bi-magic text-muted" data-bs-toggle="tooltip" title="Completion handler"></i>
                            }
                            else if (content.Type == typeof(TwEmojiPluginHandlerAttribute))
                            {
                                <i class="bi bi-emoji-smile text-muted" data-bs-toggle="tooltip" title="Emoji handler"></i>
                            }
                            else if (content.Type == typeof(TwExceptionPluginHandlerAttribute))
                            {
                                <i class="bi bi-exclamation-triangle text-danger" data-bs-toggle="tooltip" title="Exception handler"></i>
                            }
                            else if (content.Type == typeof(TwExternalLinkPluginHandlerAttribute))
                            {
                                <i class="bi bi-box-arrow-up-right text-info" data-bs-toggle="tooltip" title="External link handler"></i>
                            }
                            else if (content.Type == typeof(TwInternalLinkPluginHandlerAttribute))
                            {
                                <i class="bi bi-link-45deg text-info" data-bs-toggle="tooltip" title="Internal link handler"></i>
                            }
                            else
                            {
                                <i class="bi bi-question-circle" data-bs-toggle="tooltip" title="Unknown type"></i>
                            }
                        </td>
                        <td class="text-nowrap">

                            @if (typeof(ITwPluginHandlerAttribute).IsAssignableFrom(content.Type) == true)
                            {
                                <a class="text-decoration-none fw-semibold" href="@WikiConfiguration.BasePath/Admin/PluginHandler/@Model.Plugin.Name/@content.Name">
                                    @content.Name
                                </a>
                            }
                            @if (typeof(ITwPluginFunctionAttribute).IsAssignableFrom(content.Type) == true)
                            {
                                <a class="text-decoration-none fw-semibold" href="@WikiConfiguration.BasePath/Admin/PluginFunction/@Model.Plugin.Name/@content.Name">
                                    @content.Name
                                </a>
                            }
                        </td>
                        <td>
                            @content.Description
                        </td>
                        <td>
                            @content.Precedence
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-muted">
                <i class="bi bi-emoji-frown me-2"></i>
                @Localizer["This plugin does not contain any funcions or handlers."]
            </div>
        </div>
    }
</div>
