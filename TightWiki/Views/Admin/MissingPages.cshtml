@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model MissingPagesViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Missing Pages"]
        </h3>
        <div class="text-muted">
            @Localizer["Pages that have been linked to, but do not exist."]
        </div>
    </div>
</div>

@if (Model.Pages.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "SourcePage")">
                                @Localizer["Source Page"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "TargetPage")">
                                @Localizer["Target Page"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Pages)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@p.SourcePageNavigation">
                                    @p.SourcePageName
                                </a>
                            </td>
                            <td>
                                <a class="text-decoration-none"
                                       href="@WikiConfiguration.BasePath/@p.TargetPageNavigation/Edit?Name=@p.TargetPageName">
                                    @p.TargetPageName
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-check-circle me-2"></i>
            @Localizer["There are currently no missing pages being referenced by other wiki pages."]
        </div>
    </div>
}