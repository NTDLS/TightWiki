@using NTDLS.Helpers
@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.Plugin.Library
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PageStatisticsViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Page Statistics"]
        </h3>
        <div class="text-muted">
            @Localizer["The latest page statistics for all wiki pages."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-bar-chart-line me-2"></i>@Localizer["Page Statistics"]
        </span>

        @TwConfirmActionHelper.GenerateWarnButton(
            WikiConfiguration.BasePath,
            Localizer["Purging the page statistics will delete all of the stored statistics for all pages. Continue?"].Value,
            Localizer["Purge Page Statistics"].Value,
            "/Admin/PurgePageStatistics",
            Context.Request.Path.Value)
    </div>

    @if (Model.Statistics.Count > 0)
    {
        <div class="card-body pb-0">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
   
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "Name")">
                                @Localizer["Name"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastCompileDateTime")">
                                @Localizer["Last Compile"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastErrorCount")">
                                @Localizer["Errors"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "TotalCompilationCount")">
                                @Localizer["Compilations"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "TotalViewCount")">
                                @Localizer["Views"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "Revisions")">
                                @Localizer["Revisions"]
                            </a>
                        </th>

                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastWikifyTimeMs")">
                                @Localizer["Build Time"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastMatchCount")">
                                @Localizer["Wiki Matches"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastOutgoingLinkCount")">
                                @Localizer["Outgoing Links"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastTagCount")">
                                @Localizer["Tags"]
                            </a>
                        </th>
                        <th scope="col" class="text-end text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@TwQueryStringConverter.OrderHelper(sessionState, "LastProcessedBodySize")">
                                @Localizer["Size"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stat in Model.Statistics)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(stat.Namespace))
                                {
                                    <a class="text-decoration-none text-muted"
                                           href="@WikiConfiguration.BasePath/Admin/Namespace/@stat.Namespace">
                                        @stat.Namespace
                                    </a>
                                    <span class="text-muted"> :: </span>
                                }

                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/@stat.Navigation">
                                    @stat.Title
                                </a>
                            </td>

                            <td class="text-nowrap text-muted">
                                @stat.LastCompileDateTime
                            </td>

                            <td class="text-end text-nowrap">
                                @if (stat.LastErrorCount > 0)
                                {
                                        <i class="bi bi-exclamation-triangle text-danger me-1"></i>@stat.LastErrorCount.ToString("N0")
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.TotalCompilationCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.TotalViewCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.Revisions.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastWikifyTimeMs.ToString("N0")<span class="text-muted">ms</span>
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastMatchCount.ToString("N0")
                            </td>
                                
                            <td class="text-end text-nowrap">
                                @stat.LastOutgoingLinkCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @stat.LastTagCount.ToString("N0")
                            </td>

                            <td class="text-end text-nowrap">
                                @Formatters.FileSize((long)stat.LastProcessedBodySize)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TwPageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-bar-chart me-2"></i>
            @Localizer["There are no compilation statistics available."]
        </div>
    }
</div>