@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Attributes.Functions
@using TightWiki.Plugin.Attributes.Handlers
@using TightWiki.Plugin.Interfaces
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model PluginFunctionViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Plugin"]</h3>
        <div class="text-muted">
            @Localizer["Global configuration for plugin function."]
        </div>
    </div>
</div>

@if (Model.Function != null)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center gap-2">
            @switch (Model.Function?.FunctionAttribute.GetType())
            {
                case Type t when t == typeof(TwProcessingInstructionFunctionPluginAttribute):
                    <i class="bi bi-cpu text-primary" data-bs-toggle="tooltip" title="Processing function"></i>
                    break;
                case Type t when t == typeof(TwScopeFunctionPluginAttribute):
                    <i class="bi bi-bounding-box text-primary" data-bs-toggle="tooltip" title="Scope function"></i>
                    break;
                case Type t when t == typeof(TwStandardFunctionPluginAttribute):
                    <i class="bi bi-gear text-primary" data-bs-toggle="tooltip" title="Standard function"></i>
                    break;
                default:
                    <i class="bi bi-question-circle" data-bs-toggle="tooltip" title="Unknown type"></i>
                    break;
            }
            @Localizer["Plugin Function"]
        </div>

        <div class="card-body">
            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Name"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.Name
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Description"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.Description
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Precedence"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.Precedence
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Demarcation"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.Demarcation
                </div>
            </div>
            
            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Post Process?"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.IsPostProcess
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["First Chance?"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.IsFirstChance
                </div>
            </div>

            <div class="d-flex ms-2 mb-1">
                <div class="fw-semibold" style="width:140px;">
                    @Localizer["Wiki Lite?"]
                </div>
                <div>
                    @Model.Function?.FunctionAttribute.IsLitePermissiable
                </div>
            </div>

            @if (Model.Function != null)
            {
                <div class="mt-3 pt-2 border-top">
                    <div class="small text-body-secondary mb-1">
                        <i class="bi bi-code-slash me-1"></i>
                        @Localizer["Function Signature"]
                    </div>

                    <div class="font-monospace px-2 py-1">
                        @Html.Raw(TightWiki.Library.SelfDocument.GetFunctionSignature(Model.Function))
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model.Function != null )
    {
        int skipCount;
        if (Model.Function.FunctionAttribute is TwScopeFunctionPluginAttribute)
        {
            skipCount = 2; //State and body.
        }
        else
        {
            skipCount = 1; //State.
        }

        @if(Model.Function.Parameters.Skip(skipCount).Count() > 0)
        {

        <div class="card shadow-sm mt-2">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-gear"></i>
                <span class="fw-semibold">@Localizer["Parameters"]</span>
            </div>

            <div class="card-body">
                @Html.Raw(TightWiki.Library.SelfDocument.GetFunctionSignatureDetailed(Model.Function))
            </div>
        </div>
        }
    }

}
