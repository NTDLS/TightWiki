@using TightWiki
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki.ViewModels.Admin
@inject ITwSharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@model DeletedPageRevisionViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.TwSessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="card shadow-sm border-warning mb-3">
    <div class="card-header bg-warning-subtle border-warning">
        <div class="fw-semibold text-dark">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localizer["Viewing a deleted page revision"]
        </div>
    </div>

    <div class="card-body">
        <div class="mb-3">
            @Localizer.Format("You are viewing a page revision which was deleted on {0} by {1}.", Model.DeletedDate, Model.DeletedByUserName)
        </div>

        <div class="d-flex flex-wrap gap-2">
            @TwConfirmActionHelper.GenerateWarnButton(
                WikiConfiguration.BasePath,
                Localizer["This will restore the deleted revision. Continue?"].Value,
                Localizer["Restore This Revision"].Value,
                $"/Admin/RestoreDeletedPageRevision/{Model.PageId}/{Model.Revision}",
                "/Admin/DeletedPageRevisions",
                Context.Request.Path.Value)
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <span class="fw-semibold">
            <i class="bi bi-file-earmark-text me-2"></i>@Localizer["Deleted Revision Content"]
        </span>
    </div>
    <div class="card-body">
        @Html.Raw(Model.Body)
    </div>
</div>