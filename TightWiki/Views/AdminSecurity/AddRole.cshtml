@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity

@using TightWiki.Resources

@model AddRoleViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static["Add Role"]
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["Create new role."]
        </div>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-shield-plus me-2"></i>@SharedLocalizer.Static["New Role"]
            </span>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-floppy me-1"></i>@SharedLocalizer.Static["Save"]
            </button>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label for="Name" class="form-label fw-semibold">
                        @SharedLocalizer.Static["Name"]
                    </label>
                    @Html.TextBoxFor(m => m.Name, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Required"].Value
                    })
                    <div class="text-danger small">
                        @Html.ValidationMessageFor(m => m.Name)
                    </div>
                </div>

                <div class="col-12">
                    <label for="Description" class="form-label fw-semibold">
                        @SharedLocalizer.Static["Description"]
                    </label>
                    @Html.TextBoxFor(m => m.Description, new
                    {
                        @class = "form-control",
                        placeholder= SharedLocalizer.Static["Optional"].Value
                    })
                    <div class="text-danger small">
                        @Html.ValidationMessageFor(m => m.Description)
                    </div>
                </div>
            </div>
        </div>
    </div>
}