@using TightWiki.Library
@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity

@using TightWiki.Resources

@model AccountRolesViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static.Format("Account Roles and Permissions for: {0}", Model.AccountName)
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["Account roles and permissions for a single account."]
        </div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="d-flex flex-wrap gap-2">
            <button type="button"
                    id="addPermissionToAccountButton"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addPermissionToAccountModal">
                <i class="bi bi-shield-plus me-1"></i>@SharedLocalizer.Static["Add Permission to Account"]
            </button>

            <button type="button"
                    id="addAccountMembershipButton"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addAccountMembershipModal">
                <i class="bi bi-person-plus me-1"></i>@SharedLocalizer.Static["Add Role to Account"]
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-shield-lock me-2"></i>@SharedLocalizer.Static["Account Permissions"]
            </span>
            <div>
                @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount_Permissions, "Page_Permissions")
            </div>
        </div>

        <div class="table-responsive">
            <table id="permissionsTable" class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width: 18%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Disposition", "Permissions")">
                                @SharedLocalizer.Static["Disposition"]
                            </a>
                        </th>
                        <th scope="col" style="width: 20%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Permission", "Permissions")">
                                @SharedLocalizer.Static["Permission"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Resource", "Permissions")">
                                @SharedLocalizer.Static["Resource"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @SharedLocalizer.Static["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var permission in Model.AssignedPermissions)
                    {
                        <tr>
                            <td class="text-nowrap">
                                @if (string.Equals(permission.PermissionDisposition, "Allow", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge border border-success text-success bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-check2 me-1"></i>@permission.PermissionDisposition
                                    </span>
                                }
                                else
                                {
                                    <span class="badge border border-danger text-danger bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-ban me-1"></i>@permission.PermissionDisposition
                                    </span>
                                }
                            </td>

                            <td>@permission.Permission</td>

                            <td>
                                @if (permission.Namespace != null)
                                {
                                    <span>
                                        <span class="text-muted">@SharedLocalizer.Static["Namespace"]:</span>
                                        @(permission.ResourceName == "*" ? SharedLocalizer.Static["ALL"] : permission.ResourceName)
                                    </span>
                                }
                                else if (permission.PageId != null)
                                {
                                    <span>
                                        <span class="text-muted">@SharedLocalizer.Static["Page"]:</span>
                                        @(permission.ResourceName == "*" ? SharedLocalizer.Static["ALL"] : permission.ResourceName)
                                    </span>
                                }
                            </td>

                            <td class="text-nowrap">
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        onclick="removePermission(this, '@permission.Id')">
                                    <i class="bi bi-trash me-1"></i>@SharedLocalizer.Static["Remove"]
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-people me-2"></i>@SharedLocalizer.Static["Account Role Membership"]
            </span>
            <div>
                @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount_Members, "Page_Memberships")
            </div>
        </div>

        <div class="table-responsive">
            <table id="membersTable" class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Role", "Memberships")">
                                @SharedLocalizer.Static["Name"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap" style="width: 1%;">
                            @SharedLocalizer.Static["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var membership in Model.Memberships)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/AdminSecurity/Role/@membership.Name">
                                    @membership.Name
                                </a>
                            </td>
                            <td class="text-nowrap">
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        onclick="removeMembership(this, '@membership.RoleId')">
                                    <i class="bi bi-person-dash me-1"></i>@SharedLocalizer.Static["Remove"]
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}