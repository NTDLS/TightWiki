@model AccountsViewModel
@using TightWiki.Plugin
@using TightWiki.Plugin.Interfaces
@using TightWiki
@using TightWiki.Library
@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity
@inject ISharedLocalizationText Localizer
@inject TwConfiguration WikiConfiguration

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer["Accounts"]
        </h3>
        <div class="text-muted">
            @Localizer["Global configuration for user accounts."]
        </div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Get))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-people me-2"></i>@Localizer["Account Management"]
            </span>

            <a class="btn btn-success"
                   href="@WikiConfiguration.BasePath/AdminSecurity/AddAccount">
                <i class="bi bi-person-plus me-1"></i>@Localizer["Add new account"]
            </a>
        </div>

        <div class="card-body">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md">
                    @Html.TextBoxFor(x => x.SearchString, new
                    {
                        @class = "form-control",
                        placeholder= Localizer["Search accounts..."].Value
                    })
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" value="Search" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>@Localizer["Search"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Users.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-body pb-0">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount, @class: "mb-3")
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Account")">
                                @Localizer["Display Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "FirstName")">
                                @Localizer["First Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastName")">
                                @Localizer["Last Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Country")">
                                @Localizer["Country"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "TimeZone")">
                                @Localizer["Time Zone"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "EmailAddress")">
                                @Localizer["Email Address"]
                            </a>
                        </th>
                        <th scope="col" class="text-nowrap">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Created")">
                                @Localizer["Created Date"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@WikiConfiguration.BasePath/AdminSecurity/Account/@user.Navigation">
                                    @user.AccountName
                                </a>
                            </td>

                            <td>@user.FirstName</td>
                            <td>@user.LastName</td>
                            <td>@user.Country</td>

                            <td class="text-nowrap text-muted">
                                @user.TimeZone
                            </td>

                            <td>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="text-break">@user.EmailAddress</span>

                                    @if (user.EmailConfirmed == true)
                                    {
                                        <span class="badge border border-success text-success bg-light rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i>@Localizer["Confirmed"]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge border border-secondary text-secondary bg-light rounded-pill">
                                            <i class="bi bi-dash-circle me-1"></i>@Localizer["Unconfirmed"]
                                        </span>
                                    }
                                </div>
                            </td>

                            <td class="text-nowrap text-muted">
                                @user.CreatedDate
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-body pt-3">
            @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount)
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">
            <i class="bi bi-person-x me-2"></i>
            @Localizer["Either there are no accounts configured or your search criteria returned no results."]
        </div>
    </div>
}

<script>
    window.onload = function () {
        document.getElementById("SearchString")?.focus();
    }
</script>
