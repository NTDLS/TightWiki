@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity
@inject IViewLocalizer Localizer
@model AccountProfileViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">@Localizer["Add Account"]</h3>
        <div class="text-muted">@Localizer["Create new user account."]</div>
    </div>
</div>

@using (Html.BeginForm(null, null, new { navigation = Model.AccountProfile.Navigation }, FormMethod.Post, true, new { action = $"{GlobalConfiguration.BasePath}{Context.Request.Path}", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.AccountProfile.Navigation)

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-person-plus me-2"></i>@Localizer["New Account"]
            </span>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-floppy me-1"></i>@Localizer["Save"]
            </button>
        </div>

        <div class="card-body">
            <div class="row g-4">
                <div class="col-12 col-lg-4">
                    <div class="card h-100 border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-image me-2"></i>@Localizer["Avatar"]
                        </div>
                        <div class="card-body text-center">
                            <div id="avatar-preview-container">
                                <img id="avatar-preview"
                                     src="@GlobalConfiguration.BasePath/Profile/Default/Avatar?max=150"
                                     alt="Image Preview"
                                     class="img-thumbnail"
                                     style="max-width: 200px; max-height: 200px;" />
                            </div>
                        </div>
                        <div class="card-footer text-center">
                            <label for="avatar" class="btn btn-outline-primary mb-0">
                                <i class="bi bi-upload me-1"></i>@Localizer["Change Avatar"]
                            </label>
                            <input type="file" id="avatar" name="Avatar" accept="image/*" class="d-none">
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-8">
                    <div class="card h-100 border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-person-lines-fill me-2"></i>@Localizer["Profile"]
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label for="AccountProfile_EmailAddress" class="form-label fw-semibold">
                                        @Localizer["Email Address"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.EmailAddress, new
                                    {
                                        @class = "form-control",
                                        placeholder = Localizer["Required"].Value
                                    })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.EmailAddress)</div>
                                </div>

                                <div class="col-12">
                                    <label for="AccountProfile_AccountName" class="form-label fw-semibold">
                                        @Localizer["Display Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.AccountName, new
                                    {
                                        @class = "form-control",
                                        placeholder = Localizer["Required"].Value
                                    })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.AccountName)</div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <label for="AccountProfile_FirstName" class="form-label fw-semibold">
                                        @Localizer["First Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.FirstName, new
                                    {
                                        @class = "form-control",
                                        placeholder = Localizer["Optional"].Value
                                    })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.FirstName)</div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <label for="AccountProfile_LastName" class="form-label fw-semibold">
                                        @Localizer["Last Name"]
                                    </label>
                                    @Html.TextBoxFor(m => m.AccountProfile.LastName, new
                                    {
                                        @class = "form-control",
                                        placeholder = Localizer["Optional"].Value
                                    })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.LastName)</div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="DefaultRole" class="form-label fw-semibold">
                                        @Localizer["Role"]
                                    </label>
                                    <select name="DefaultRole" id="DefaultRole" class="form-select">
                                        <option value="">@Localizer["Select a role"]</option>
                                        @foreach (var item in Model.Roles)
                                        {
                                            <option value="@item.Name" selected="@(Model.DefaultRole == item.Name ? "selected" : null)">
                                                @item.Name
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.DefaultRole)</div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="AccountProfile_Country" class="form-label fw-semibold">
                                        @Localizer["Country"]
                                    </label>
                                    <select name="AccountProfile.Country" id="AccountProfile_Country" class="form-select">
                                        <option value="">@Localizer["Select a country"]</option>
                                        @foreach (var item in Model.Countries)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.Country == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.Country)</div>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label for="AccountProfile_Language" class="form-label fw-semibold">
                                        @Localizer["Language"]
                                    </label>
                                    <select name="AccountProfile.Language" id="AccountProfile_Language" class="form-select">
                                        <option value="">@Localizer["Select a language"]</option>
                                        @foreach (var item in Model.Languages)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.Language == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.Language)</div>
                                </div>

                                <div class="col-12">
                                    <label for="AccountProfile_TimeZone" class="form-label fw-semibold">
                                        @Localizer["Time Zone"]
                                    </label>
                                    <select name="AccountProfile.TimeZone" id="AccountProfile_TimeZone" class="form-select">
                                        <option value="">@Localizer["Select a time-zone"]</option>
                                        @foreach (var item in Model.TimeZones)
                                        {
                                            <option value="@item.Value" selected="@(Model.AccountProfile.TimeZone == item.Value ? "selected" : null)">
                                                @item.Text
                                            </option>
                                        }
                                    </select>
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.TimeZone)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-key me-2"></i>@Localizer["Credentials"]
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label for="Credential_Password" class="form-label fw-semibold">
                                        @Localizer["Password"]
                                    </label>
                                    @Html.PasswordFor(m => m.Credential.Password, new { @class = "form-control" })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.Credential.Password)</div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <label for="Credential_ComparePassword" class="form-label fw-semibold">
                                        @Localizer["Confirm Password"]
                                    </label>
                                    @Html.PasswordFor(m => m.Credential.ComparePassword, new { @class = "form-control" })
                                    <div class="text-danger small">@Html.ValidationMessageFor(m => m.Credential.ComparePassword)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border">
                        <div class="card-header fw-semibold">
                            <i class="bi bi-card-text me-2"></i>@Localizer["Biography"]
                        </div>
                        <div class="card-body">
                            <label for="Biography" class="form-label fw-semibold">
                                @Localizer["Biography"]
                            </label>
                            @Html.TextAreaFor(m => m.AccountProfile.Biography, new
                            {
                                @class = "form-control",
                                style = "min-height: 220px",
                                Name = "Biography"
                            })
                            <div class="text-danger small">@Html.ValidationMessageFor(m => m.AccountProfile.Biography)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let fileInput = document.getElementById("avatar");

        if (fileInput) {
            fileInput.addEventListener("change", function (event) {
                let file = event.target.files[0];
                if (file) {
                    let reader = new FileReader();

                    reader.onload = function (e) {
                        let preview = document.getElementById("avatar-preview");
                        let previewContainer = document.getElementById("avatar-preview-container");

                        if (preview) {
                            preview.src = e.target.result;
                        } else if (previewContainer) {
                            previewContainer.innerHTML =
                                `<img id="avatar-preview"
                                      src="${e.target.result}"
                                      alt="Image Preview"
                                      class="img-thumbnail"
                                      style="max-width: 200px; max-height: 200px;">`;
                        }

                        if (previewContainer) {
                            previewContainer.style.display = "block";
                        }
                    };

                    reader.readAsDataURL(file);
                }
            });
        }
    });
</script>