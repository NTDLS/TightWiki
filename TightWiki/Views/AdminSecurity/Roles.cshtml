@model RolesViewModel
@using TightWiki.Library
@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity

@using TightWiki.Resources

@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @SharedLocalizer.Static["Roles"]
        </h3>
        <div class="text-muted">
            @SharedLocalizer.Static["Global configuration for security roles and membership."]
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-shield-lock me-2"></i>@SharedLocalizer.Static["Security Roles"]
        </span>

        <a href="@GlobalConfiguration.BasePath/AdminSecurity/AddRole"
               class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>@SharedLocalizer.Static["Add Role"]
        </a>
    </div>

    @if (Model.Roles.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width: 30%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Name")">
                                @SharedLocalizer.Static["Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Description")">
                                @SharedLocalizer.Static["Description"]
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/AdminSecurity/Role/@role.Name">
                                    @role.Name
                                </a>
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(role.Description)
                                    ? SharedLocalizer.Static["(No description)"].Value
                                    : role.Description)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card-body text-muted">
            <i class="bi bi-shield-x me-2"></i>
            @SharedLocalizer.Static["There are no security roles configured."]
        </div>
    }
</div>