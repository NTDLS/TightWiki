@using TightWiki.Library
@using TightWiki.Models
@using TightWiki.Models.ViewModels.AdminSecurity
@inject ISharedLocalizationText Localizer

@model RoleViewModel
@{
    Layout = "_Layout";
    var sessionState = ViewData["SessionState"] as TightWiki.SessionState ?? throw new Exception("Wiki State Context cannot be null.");
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h3 class="mb-1">
            @Localizer.Format("Role: {0}", Model.Name)
        </h3>
        <div class="text-muted">
            @Localizer["Role membership and permissions."]
        </div>
    </div>
</div>

@using (Html.BeginForm(FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="d-flex flex-wrap gap-2">
            <button type="button"
                    id="addPermissionToRoleButton"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addPermissionToRoleModal">
                <i class="bi bi-shield-plus me-1"></i>@Localizer["Add Permission to Role"]
            </button>

            <button type="button"
                    id="addMemberToRoleButton"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addMemberToRoleModal">
                <i class="bi bi-person-plus me-1"></i>@Localizer["Add Member to Role"]
            </button>
        </div>

        @if (Model.IsBuiltIn != true)
        {
            @ConfirmActionHelper.GenerateDangerButton(
                GlobalConfiguration.BasePath,
                Localizer["Deleting the role '{0}' will revoke any permissions granted or denied by that role. Continue?"].Format(Model.Name),
                Localizer["Delete Role"].Value,
                $"/AdminSecurity/DeleteRole/{Model.Id}",
                $"{GlobalConfiguration.BasePath}/AdminSecurity/Roles",
                Context.Request.Path.Value)
        }
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-shield-lock me-2"></i>@Localizer["Role Permissions"]
            </span>
            <div>
                @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount_Permissions, "Page_Permissions")
            </div>
        </div>

        <div class="table-responsive">
            <table id="permissionsTable" class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width: 18%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Disposition", "Permissions")">
                                @Localizer["Disposition"]
                            </a>
                        </th>
                        <th scope="col" style="width: 20%;">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Permission", "Permissions")">
                                @Localizer["Permission"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "Resource", "Permissions")">
                                @Localizer["Resource"]
                            </a>
                        </th>
                        <th scope="col" style="width: 1%;" class="text-nowrap">
                            @Localizer["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var permission in Model.AssignedPermissions)
                    {
                        <tr>
                            <td class="text-nowrap">
                                @if (string.Equals(permission.PermissionDisposition, "Allow", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge border border-success text-success bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-check2 me-1"></i>@permission.PermissionDisposition
                                    </span>
                                }
                                else
                                {
                                    <span class="badge border border-danger text-danger bg-light rounded-pill px-3 py-2">
                                        <i class="bi bi-ban me-1"></i>@permission.PermissionDisposition
                                    </span>
                                }
                            </td>

                            <td>@permission.Permission</td>

                            <td>
                                @if (permission.Namespace != null)
                                {
                                    <span>
                                        <span class="text-muted">@Localizer["Namespace"]:</span>
                                        @(permission.ResourceName == "*" ? Localizer["ALL"] : permission.ResourceName)
                                    </span>
                                }
                                else if (permission.PageId != null)
                                {
                                    <span>
                                        <span class="text-muted">@Localizer["Page"]:</span>
                                        @(permission.ResourceName == "*" ? Localizer["ALL"] : permission.ResourceName)
                                    </span>
                                }
                            </td>

                            <td class="text-nowrap">
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        onclick="removePermission(this, '@permission.Id')">
                                    <i class="bi bi-trash me-1"></i>@Localizer["Remove"]
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="fw-semibold">
                <i class="bi bi-people me-2"></i>@Localizer["Role Members"]
            </span>
            <div>
                @TightWiki.Library.PageSelectorGenerator.Generate(Context.Request.QueryString, Model.PaginationPageCount_Members, "Page_Members")
            </div>
        </div>

        <div class="table-responsive">
            <table id="membersTable" class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "AccountName", "Members")">
                                @Localizer["Display Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "EmailAddress", "Members")">
                                @Localizer["Email Address"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "FirstName", "Members")">
                                @Localizer["First Name"]
                            </a>
                        </th>
                        <th scope="col">
                            <a class="link-dark text-decoration-none"
                                   href="?@QueryStringConverter.OrderHelper(sessionState, "LastName", "Members")">
                                @Localizer["Last Name"]
                            </a>
                        </th>
                        <th scope="col" style="width: 1%;" class="text-nowrap">
                            @Localizer["Action"]
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Members)
                    {
                        <tr>
                            <td>
                                <a class="text-decoration-none fw-semibold"
                                       href="@GlobalConfiguration.BasePath/AdminSecurity/Account/@member.Navigation">
                                    @member.AccountName
                                </a>
                            </td>
                            <td>@member.EmailAddress</td>
                            <td>@member.FirstName</td>
                            <td>@member.LastName</td>
                            <td class="text-nowrap">
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        onclick="removeMember(this, '@member.UserId')">
                                    <i class="bi bi-person-dash me-1"></i>@Localizer["Remove"]
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}